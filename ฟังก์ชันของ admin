local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

-- ADMIN
local admins = {
["ใส่ชื่อ admin1"] = true,
["ใส่ชื่อ admin2"] = true
}

if not admins[player.Name] then return end

local char = player.Character or player.CharacterAdded:Wait()
local humanoid = char:WaitForChild("Humanoid")

-- GUI
local gui = Instance.new("ScreenGui")
gui.Parent = player.PlayerGui

-- ADMIN BUTTON
local vip = Instance.new("TextButton")
vip.Size = UDim2.new(0,100,0,100)
vip.Position = UDim2.new(0.85,0,0.4,0)
vip.Text = "เฉพาะ\nADMIN"
vip.TextScaled = true
vip.Font = Enum.Font.SourceSansBold
vip.TextColor3 = Color3.new(1,1,1)
vip.TextStrokeTransparency = 0
vip.TextStrokeColor3 = Color3.new(0,0,0)
vip.BackgroundColor3 = Color3.fromRGB(255,200,0)
vip.Parent = gui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(1,0)
corner.Parent = vip

-- MENU FRAME
local menuFrame = Instance.new("Frame")
menuFrame.Size = UDim2.new(0,220,0,150)
menuFrame.Position = UDim2.new(0.85,-230,0.4,110)
menuFrame.BackgroundColor3 = Color3.fromRGB(30,30,30)
menuFrame.Visible = false
menuFrame.Parent = gui

-- SCROLL MENU
local menu = Instance.new("ScrollingFrame")
menu.Size = UDim2.new(1,0,1,0)
menu.CanvasSize = UDim2.new(0,0,0,350)
menu.ScrollBarThickness = 6
menu.BackgroundTransparency = 1
menu.Parent = menuFrame

local function makeButton(text,y)
    
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1,-20,0,40)
    b.Position = UDim2.new(0,10,0,y)
    b.Text = text
    b.Parent = menu
    
    return b
    
end

local fast = makeButton("เดินเร็ว : ปิด",10)
local wall = makeButton("ทะลุกำแพง : ปิด",60)
local god = makeButton("อมตะ : ปิด",110)
local jump = makeButton("กระโดดไม่จำกัด : ปิด",160)
local tp = makeButton("เทเลพอร์ต",210)
local kick = makeButton("เตะผู้เล่น",260)

-- STATES
local fastOn=false
local noclip=false
local godOn=false
local jumpOn=false

-- FAST WALK
fast.MouseButton1Click:Connect(function()
    
    fastOn = not fastOn
    
    if fastOn then
        humanoid.WalkSpeed = 50
        fast.Text="เดินเร็ว : เปิด"
    else
        humanoid.WalkSpeed = 16
        fast.Text="เดินเร็ว : ปิด"
    end
    
end)

-- NOCLIP
RunService.Stepped:Connect(function()
    
    if noclip then
        for _,v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then
                v.CanCollide=false
            end
        end
    end
    
end)

wall.MouseButton1Click:Connect(function()
    
    noclip = not noclip
    
    if noclip then
        wall.Text="ทะลุกำแพง : เปิด"
    else
        wall.Text="ทะลุกำแพง : ปิด"
    end
    
end)

-- GOD MODE
local shield

RunService.RenderStepped:Connect(function()
    
    if godOn then
        if humanoid.Health < humanoid.MaxHealth then
            humanoid.Health = humanoid.MaxHealth
        end
    end
    
end)

god.MouseButton1Click:Connect(function()
    
    godOn = not godOn
    
    if godOn then
        god.Text="อมตะ : เปิด"
        shield = Instance.new("ForceField")
        shield.Parent = char
    else
        god.Text="อมตะ : ปิด"
        if shield then shield:Destroy() end
    end
    
end)

-- UNLIMITED JUMP
jump.MouseButton1Click:Connect(function()
    
    jumpOn = not jumpOn
    
    if jumpOn then
        jump.Text="กระโดดไม่จำกัด : เปิด"
    else
        jump.Text="กระโดดไม่จำกัด : ปิด"
    end
    
end)

UIS.JumpRequest:Connect(function()
    
    if jumpOn then
        humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    end
    
end)

-- VIP MENU
vip.MouseButton1Click:Connect(function()
    
    menuFrame.Visible = not menuFrame.Visible
    
end)

-- DRAG
local dragging=false

vip.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragging=true
    end
end)

vip.InputEnded:Connect(function()
    dragging=false
end)

vip.InputChanged:Connect(function(input)
    
    if dragging then
        
        local x=input.Position.X
        local y=input.Position.Y
        
        vip.Position=UDim2.new(0,x-50,0,y-50)
        menuFrame.Position=UDim2.new(0,x-230,0,y+70)
        
    end
    
end)
