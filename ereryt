local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")

-- ไฟล์สำหรับจำเซิร์ฟเวอร์ที่เคยไปมาแล้ว (เพื่อไม่ให้กลับไปที่เดิม)
local CacheFile = "PisitVisitedServers.json"

local function GetVisitedServers()
    if isfile and isfile(CacheFile) then
        local success, result = pcall(function()
            return HttpService:JSONDecode(readfile(CacheFile))
        end)
        if success then return result end
    end
    return {}
end

local function SaveVisitedServer(jobId)
    local visited = GetVisitedServers()
    visited[jobId] = os.time()
    
    -- ล้างข้อมูลเซิร์ฟที่บันทึกไว้นานเกิน 1 ชั่วโมง (เพื่อไม่ให้ไฟล์ใหญ่เกินไป)
    for id, timestamp in pairs(visited) do
        if os.time() - timestamp > 3600 then
            visited[id] = nil
        end
    end
    
    if writefile then
        writefile(CacheFile, HttpService:JSONEncode(visited))
    end
end

local function Hop()
    local visited = GetVisitedServers()
    local placeId = game.PlaceId
    local selfJobId = game.JobId
    
    -- ดึงรายการเซิร์ฟเวอร์จาก API ของ Roblox
    local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Desc&limit=100"
    local success, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(url))
    end)
    
    if success and result and result.data then
        for _, server in pairs(result.data) do
            -- เงื่อนไข: 
            -- 1. ต้องไม่ใช่เซิร์ฟเวอร์ปัจจุบัน
            -- 2. ต้องไม่เคยไปมาก่อน (ตามที่บันทึกไว้ในไฟล์)
            -- 3. เซิร์ฟเวอร์ต้องไม่เต็ม
            if server.id ~= selfJobId and not visited[server.id] and server.playing < server.maxPlayers then
                SaveVisitedServer(selfJobId) -- บันทึกเซิร์ฟปัจจุบันก่อนจากไป
                TeleportService:TeleportToPlaceInstance(placeId, server.id, Players.LocalPlayer)
                return
            end
        end
    end
    
    -- ถ้าวนหาจนครบ 100 เซิร์ฟแล้วยังไม่เจอที่ถูกใจ ให้สุ่มไปเซิร์ฟที่คนน้อยที่สุดแทน
    task.wait(1)
    print("หาเซิร์ฟเวอร์ใหม่ที่ยังไม่เคยไปไม่ได้, กำลังลองใหม่...")
    -- วนลูปค้นหาใหม่จนกว่าจะสำเร็จ
    Hop()
end

-- รันทันทีที่กด Run Script
Hop()
