-- [ ระบบ UI ]
---------------------------------------------------------
local sg = Instance.new("ScreenGui", LocalPlayer.PlayerGui)
sg.Name = "PisitRecorderUI"
sg.ResetOnSpawn = false

local main = Instance.new("Frame", sg)
main.Size = UDim2.new(0, 180, 0, 150)
main.Position = UDim2.new(0.5, -90, 0.1, 0)
main.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
Instance.new("UICorner", main)

local function createBtn(text, pos, color, func)
    local b = Instance.new("TextButton", main)
    b.Size = UDim2.new(0.9, 0, 0, 35)
    b.Position = pos
    b.BackgroundColor3 = color
    b.Text = text
    b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = "SourceSansBold"
    b.TextSize = 16
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(func)
    return b
end

local recordBtn = createBtn("เริ่มบันทึก (สีเขียว)", UDim2.new(0.05, 0, 0.1, 0), Color3.fromRGB(50, 150, 50), function()
    if not IsRecording then
        StartRecording()
    else
        StopRecording()
    end
end)

local playBtn = createBtn("ทำซ้ำ (Replay)", UDim2.new(0.05, 0, 0.4, 0), Color3.fromRGB(0, 120, 200), StartPlayback)

local stopPlayBtn = createBtn("หยุดทำซ้ำ", UDim2.new(0.05, 0, 0.7, 0), Color3.fromRGB(150, 50, 50), function()
    IsPlaying = false
end)

-- ระบบอัปเดตข้อความปุ่มบันทึก
RunService.RenderStepped:Connect(function()
    if IsRecording then
        recordBtn.Text = "กำลังบันทึก.. " .. math.floor(Timer) .. "s (กดหยุด)"
        recordBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    else
        recordBtn.Text = "เริ่มบันทึกสีเขียว"
        recordBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
    end
end)

-- ระบบลาก UI
local dragging, dragInput, dragStart, startPos
main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; dragStart = input.Position; startPos = main.Position end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
