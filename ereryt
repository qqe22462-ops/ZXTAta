-- [ ระบบ UI (แยกโซนสีชัดเจน) ]
---------------------------------------------------------
if LocalPlayer.PlayerGui:FindFirstChild("PisitDualUI") then
    LocalPlayer.PlayerGui.PisitDualUI:Destroy()
end

local sg = Instance.new("ScreenGui", LocalPlayer.PlayerGui)
sg.Name = "PisitDualUI"
sg.ResetOnSpawn = false

local main = Instance.new("Frame", sg)
main.Size = UDim2.new(0, 200, 0, 180)
main.Position = UDim2.new(0.8, 0, 0.4, 0)
main.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
main.Active = true
Instance.new("UICorner", main)

local function createBtn(text, pos, color, func)
    local b = Instance.new("TextButton", main)
    b.Size = UDim2.new(0.42, 0, 0, 35)
    b.Position = pos
    b.BackgroundColor3 = color
    b.Text = text
    b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = "SourceSansBold"
    b.TextSize = 12
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(func)
    return b
end

-- แถวที่ 1: จัดการจุด A (สีฟ้า)
local titleA = Instance.new("TextLabel", main)
titleA.Size = UDim2.new(1, 0, 0, 25); titleA.Text = "--- ZONE A ---"; titleA.TextColor3 = Color3.fromRGB(0, 255, 255); titleA.BackgroundTransparency = 1

createBtn("SET A", UDim2.new(0.05, 0, 0.15, 0), Color3.fromRGB(0, 100, 150), function() HandleA("SET") end)
createBtn("GO TO A", UDim2.new(0.53, 0, 0.15, 0), Color3.fromRGB(0, 150, 200), function() HandleA("TP") end)

-- แถวที่ 2: จัดการจุด B (สีส้ม)
local titleB = Instance.new("TextLabel", main)
titleB.Size = UDim2.new(1, 0, 0, 25); titleB.Position = UDim2.new(0, 0, 0.45, 0); titleB.Text = "--- ZONE B ---"; titleB.TextColor3 = Color3.fromRGB(255, 170, 0); titleB.BackgroundTransparency = 1

createBtn("SET B", UDim2.new(0.05, 0, 0.6, 0), Color3.fromRGB(150, 100, 0), function() HandleB("SET") end)
createBtn("GO TO B", UDim2.new(0.53, 0, 0.6, 0), Color3.fromRGB(200, 130, 0), function() HandleB("TP") end)

---------------------------------------------------------
-- [ ระบบลาก UI ]
---------------------------------------------------------
local dragging, dragInput, dragStart, startPos
main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; dragStart = input.Position; startPos = main.Position end
end)
main.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end
end)
UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
