local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

-- ตัวแปรเก็บพิกัดแยกกัน
local PointA = nil
local PointB = nil

-- ตัวแสดงผลในแมพ (Visuals)
local VisualA = nil
local VisualB = nil

---------------------------------------------------------
-- [ ฟังก์ชันการทำงาน ]
---------------------------------------------------------

-- สร้างแผ่นมาร์คบอกตำแหน่งบนพื้น
local function CreateVisual(pos, color, name)
    local p = Instance.new("Part")
    p.Name = name
    p.Size = Vector3.new(4, 0.5, 4)
    p.CFrame = pos * CFrame.new(0, -3.2, 0)
    p.Anchored = true
    p.CanCollide = false
    p.Transparency = 0.4
    p.Material = Enum.Material.Neon
    p.Color = color
    p.Parent = workspace
    
    -- ใส่ตัวหนังสือบอกบนหัว Part
    local bgu = Instance.new("BillboardGui", p)
    bgu.Size = UDim2.new(0, 100, 0, 50)
    bgu.Adornee = p
    bgu.AlwaysOnTop = true
    bgu.ExtentsOffset = Vector3.new(0, 3, 0)
    
    local tl = Instance.new("TextLabel", bgu)
    tl.Size = UDim2.new(1, 0, 1, 0)
    tl.BackgroundTransparency = 1
    tl.Text = name
    tl.TextColor3 = color
    tl.Font = "SourceSansBold"
    tl.TextSize = 20
    
    return p
end

-- ระบบจัดการจุด A
local function HandleA(mode)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    if mode == "SET" then
        PointA = char.HumanoidRootPart.CFrame
        if VisualA then VisualA:Destroy() end
        VisualA = CreateVisual(PointA, Color3.fromRGB(0, 255, 255), "POINT A")
    elseif mode == "TP" then
        if PointA then char.HumanoidRootPart.CFrame = PointA end
    end
end

-- ระบบจัดการจุด B
local function HandleB(mode)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    if mode == "SET" then
        PointB = char.HumanoidRootPart.CFrame
        if VisualB then VisualB:Destroy() end
        VisualB = CreateVisual(PointB, Color3.fromRGB(255, 170, 0), "POINT B")
    elseif mode == "TP" then
        if PointB then char.HumanoidRootPart.CFrame = PointB end
    end
end

