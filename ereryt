local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local PlaceId = game.PlaceId
local FileName = "PisitSave_" .. PlaceId .. ".txt" -- ชื่อไฟล์แยกตามแมพ

local SavedCFrame = nil

---------------------------------------------------------
-- [ ฟังก์ชันจัดการไฟล์ (Save/Load) ]
---------------------------------------------------------

-- ฟังก์ชันบันทึกลงเครื่อง
local function SaveToFile(cf)
    local data = tostring(cf)
    if writefile then
        writefile(FileName, data)
        return true
    end
    return false
end

-- ฟังก์ชันโหลดจากเครื่อง
local function LoadFromFile()
    if isfile and isfile(FileName) then
        local data = readfile(FileName)
        -- แปลงข้อความกลับเป็น CFrame
        local components = {}
        for val in data:gmatch("[^, ]+") do
            table.insert(components, tonumber(val))
        end
        return CFrame.new(unpack(components))
    end
    return nil
end

