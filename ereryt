local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

local RecordedData = {} 
local IsRecording = false
local IsPlaying = false
local Timer = 0

---------------------------------------------------------
-- [ ฟังก์ชันหลัก ]
---------------------------------------------------------

-- 1. เริ่มบันทึก (ความละเอียด 0.1 วินาที)
local function StartRecording()
    if IsPlaying then return end
    RecordedData = {} 
    Timer = 0
    IsRecording = true
    print("เริ่มบันทึกแบบละเอียด 0.1s...")
    
    task.spawn(function()
        while IsRecording and Timer < 60 do
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local hrp = char.HumanoidRootPart
                local hum = char:FindFirstChildOfClass("Humanoid")
                
                -- บันทึกพิกัดแบบละเอียด (รองรับทั้งเดินและบิน)
                table.insert(RecordedData, {
                    cf = hrp.CFrame,
                    speed = (hum and hum.WalkSpeed) or 16,
                    jump = (hum and hum.JumpPower) or 50,
                })
            end
            task.wait(0.1) -- บันทึกทุกๆ 0.1 วินาทีตามสั่ง
            Timer = Timer + 0.1
        end
        if IsRecording then IsRecording = false end
    end)
end

-- 2. ทำซ้ำ (Playback แบบรองรับการลอยตัว/บิน)
local function StartPlayback()
    if IsRecording or #RecordedData == 0 then return end
    IsPlaying = true
    print("กำลังทำซ้ำการเล่น (รวมสถานะการบิน)...")
    
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local hrp = char.HumanoidRootPart
        local hum = char:FindFirstChildOfClass("Humanoid")
        
        -- ปิดระบบฟิสิกส์ชั่วคราวเพื่อให้ลอยตัวได้เหมือนตอนบิน
        hrp.Anchored = true 
        
        for _, data in ipairs(RecordedData) do
            if not IsPlaying then break end
            
            -- ย้ายตำแหน่งไปยังพิกัดที่บันทึกไว้ (รวมถึงความสูงตอนบิน)
            hrp.CFrame = data.cf
            
            if hum then
                hum.WalkSpeed = data.speed
                hum.JumpPower = data.jump
            end
            
            task.wait(0.1) -- เล่นคืนที่ความเร็ว 0.1 วินาที
        end
        
        hrp.Anchored = false -- เปิดระบบฟิสิกส์คืนเมื่อจบ
    end
    IsPlaying = false
    print("ทำซ้ำเสร็จสิ้น!")
end

