local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

local RecordedData = {} -- ที่เก็บข้อมูลที่บันทึกไว้
local IsRecording = false
local IsPlaying = false
local Timer = 0

---------------------------------------------------------
-- [ ฟังก์ชันหลัก ]
---------------------------------------------------------

-- 1. เริ่มบันทึก
local function StartRecording()
    if IsPlaying then return end
    RecordedData = {} -- ล้างข้อมูลเก่า
    Timer = 0
    IsRecording = true
    print("เริ่มบันทึกข้อมูล...")
    
    task.spawn(function()
        while IsRecording and Timer < 60 do
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") then
                local hrp = char.HumanoidRootPart
                local hum = char.Humanoid
                
                -- บันทึกค่าที่จุดเวลานั้นๆ
                table.insert(RecordedData, {
                    cf = hrp.CFrame,
                    speed = hum.WalkSpeed,
                    jump = hum.JumpPower,
                    time = Timer
                })
            end
            task.wait(0.1) -- บันทึกความละเอียดสูง (ทุก 0.1 วินาที)
            Timer = Timer + 0.1
        end
        if IsRecording then StopRecording() end
    end)
end

-- 2. หยุดบันทึก
function StopRecording()
    IsRecording = false
    print("หยุดบันทึก! บันทึกได้ทั้งหมด " .. #RecordedData .. " จุด")
end

-- 3. ทำซ้ำ (Playback)
local function StartPlayback()
    if IsRecording or #RecordedData == 0 then return end
    IsPlaying = true
    print("กำลังทำซ้ำการเล่น...")
    
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local hrp = char.HumanoidRootPart
        local hum = char:FindFirstChildOfClass("Humanoid")
        
        for _, data in ipairs(RecordedData) do
            if not IsPlaying then break end
            
            -- บังคับตัวละครให้มีค่าตามที่บันทึกไว้
            hrp.CFrame = data.cf
            if hum then
                hum.WalkSpeed = data.speed
                hum.JumpPower = data.jump
            end
            task.wait(0.1) -- เล่นคืนตามความเร็วที่บันทึก
        end
    end
    IsPlaying = false
    print("ทำซ้ำเสร็จสิ้น!")
end

