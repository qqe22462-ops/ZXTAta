---------------------------------------------------------
-- [ ระบบการทำงาน ]
---------------------------------------------------------

-- คลิกปุ่ม E เพื่อขอเซฟ
eButton.MouseButton1Click:Connect(function()
    confirmFrame.Visible = true
end)

-- กดยกเลิก
cancelBtn.MouseButton1Click:Connect(function()
    confirmFrame.Visible = false
end)

-- กดตกลง (บันทึกจริง)
okBtn.MouseButton1Click:Connect(function()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        SavedCFrame = char.HumanoidRootPart.CFrame
        SaveToFile(SavedCFrame)
        tpBtn.Visible = true
        confirmFrame.Visible = false
        print("บันทึกพิกัดแมพ " .. PlaceId .. " เรียบร้อย!")
    end
end)

-- กดวาร์ป
tpBtn.MouseButton1Click:Connect(function()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") and SavedCFrame then
        char.HumanoidRootPart.CFrame = SavedCFrame
    end
end)

-- [[ AUTO LOAD: ทันทีที่รันสคริปต์ ]]
task.spawn(function()
    local loadedPos = LoadFromFile()
    if loadedPos then
        SavedCFrame = loadedPos
        tpBtn.Visible = true
        print("โหลดจุดเดิมจากแมพ " .. PlaceId .. " สำเร็จ!")
    end
end)

-- ระบบลากปุ่ม E
local dragStart, startPos, dragging
eButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true; dragStart = input.Position; startPos = eButton.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        eButton.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        tpBtn.Position = UDim2.new(eButton.Position.X.Scale, eButton.Position.X.Offset + 60, eButton.Position.Y.Scale, eButton.Position.Y.Offset + 5)
    end
end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
