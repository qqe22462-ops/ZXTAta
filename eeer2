-- ระบบเก็บกล่องอัญมณีอัตโนมัติ + ปรับรัศมี + วงกลมแสดงผล

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local IsActive = false
local Radius = 50 -- ค่าเริ่มต้น

-- [[ สร้าง UI ]]
local sg = Instance.new("ScreenGui", LocalPlayer.PlayerGui)
sg.Name = "PisitChestUI"
sg.ResetOnSpawn = false

local main = Instance.new("Frame", sg)
main.Size = UDim2.new(0, 220, 0, 150)
main.Position = UDim2.new(0.5, -110, 0.2, 0)
main.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
main.Active = true
Instance.new("UICorner", main)

-- ปุ่มเปิด/ปิด (Toggle)
local toggleBtn = Instance.new("TextButton", main)
toggleBtn.Size = UDim2.new(0, 180, 0, 40)
toggleBtn.Position = UDim2.new(0.5, -90, 0.15, 0)
toggleBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
toggleBtn.Text = "เปิดกล่อง: OFF"
toggleBtn.TextColor3 = Color3.new(1, 1, 1)
toggleBtn.Font = "SourceSansBold"
Instance.new("UICorner", toggleBtn)

-- แถบเลื่อนปรับรัศมี (Slider Frame)
local sliderFrame = Instance.new("Frame", main)
sliderFrame.Size = UDim2.new(0, 180, 0, 10)
sliderFrame.Position = UDim2.new(0.5, -90, 0.65, 0)
sliderFrame.BackgroundColor3 = Color3.fromRGB(60, 60, 60)

local sliderDot = Instance.new("TextButton", sliderFrame)
sliderDot.Size = UDim2.new(0, 15, 0, 25)
sliderDot.Position = UDim2.new(0.5, -7, 0.5, -12)
sliderDot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
sliderDot.Text = ""
Instance.new("UICorner", sliderDot)

local radiusLabel = Instance.new("TextLabel", main)
radiusLabel.Size = UDim2.new(1, 0, 0, 20)
radiusLabel.Position = UDim2.new(0, 0, 0.75, 0)
radiusLabel.BackgroundTransparency = 1
radiusLabel.Text = "รัศมี: 50"
radiusLabel.TextColor3 = Color3.new(1, 1, 1)
radiusLabel.Font = "SourceSansBold"

-- [[ สร้างวงกลมแดงแจ้งเตือนรัศมี ]]
local highlightCircle = Instance.new("Part")
highlightCircle.Shape = Enum.PartType.Cylinder
highlightCircle.Size = Vector3.new(0.5, Radius * 2, Radius * 2)
highlightCircle.Color = Color3.fromRGB(255, 0, 0)
highlightCircle.Transparency = 0.7
highlightCircle.Material = Enum.Material.ForceField
highlightCircle.CanCollide = false
highlightCircle.Anchored = true
highlightCircle.Rotation = Vector3.new(0, 0, 90)
highlightCircle.Parent = workspace

---------------------------------------------------------
-- [ ฟังก์ชันการทำงาน ]
---------------------------------------------------------

-- ระบบ Slider (ปรับ 1-100)
local draggingSlider = false
sliderDot.MouseButton1Down:Connect(function() draggingSlider = true end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then draggingSlider = false end end)

UserInputService.InputChanged:Connect(function(input)
    if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local mouseX = input.Position.X
        local sliderX = sliderFrame.AbsolutePosition.X
        local sliderWidth = sliderFrame.AbsoluteSize.X
        local percent = math.clamp((mouseX - sliderX) / sliderWidth, 0, 1)
        
        sliderDot.Position = UDim2.new(percent, -7, 0.5, -12)
        Radius = math.floor(percent * 100)
        if Radius < 1 then Radius = 1 end
        radiusLabel.Text = "รัศมี: " .. Radius
        highlightCircle.Size = Vector3.new(0.5, Radius * 2, Radius * 2)
    end
end)

-- ปุ่มเปิด/ปิด
toggleBtn.MouseButton1Click:Connect(function()
    IsActive = not IsActive
    if IsActive then
        toggleBtn.Text = "เปิดกล่อง: ON"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
    else
        toggleBtn.Text = "เปิดกล่อง: OFF"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
    end
end)

-- ระบบเก็บอัตโนมัติ (วนลูป)
RunService.RenderStepped:Connect(function()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        highlightCircle.Position = char.HumanoidRootPart.Position - Vector3.new(0, 3, 0)
        
        if IsActive then
            -- ค้นหากล่องอัญมณีในรัศมี
            for _, obj in pairs(workspace:GetDescendants()) do
                -- ตรวจสอบชื่อกล่อง (ปรับชื่อตามในเกมของคุณ)
                if obj.Name == "กล่องอัญมณี" or obj:FindFirstChild("กล่องอัญมณี") then
                    local targetPos = obj:IsA("Model") and obj:GetPivot().Position or obj.Position
                    local distance = (char.HumanoidRootPart.Position - targetPos).Magnitude
                    
                    if distance <= Radius then
                        -- จำลองการกด (Interact)
                        -- ถ้ามี ProximityPrompt ให้ใช้คำสั่งนี้:
                        local prompt = obj:FindFirstChildOfClass("ProximityPrompt") or obj.Parent:FindFirstChildOfClass("ProximityPrompt")
                        if prompt then
                            fireproximityprompt(prompt)
                        end
                    end
                end
            end
        end
    end
end)

-- ระบบลาก UI
local dragging, dragStart, startPos
main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = main.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function() dragging = false end)
