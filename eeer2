---------------------------------------------------------
-- [ ระบบ Loop การทำงาน Logic: คุ้ย 2 ครั้ง ขาย 1 ครั้ง ]
---------------------------------------------------------

task.spawn(function()
    while true do
        RunService.Heartbeat:Wait()
        local loopCount = States.UltraSpeed and 100 or 1
        
        for i = 1, loopCount do
            -- ทำงาน 2 รอบก่อนขาย (เพื่อให้คุ้ย 2 ครั้ง)
            for step = 1, 2 do
                if States.Trash then ReplicatedStorage.TrashLoot:FireServer("Trash Can") end
                if States.Present then ReplicatedStorage.TrashLoot:FireServer("Present Pile") end
                if States.FarmL2 then ReplicatedStorage.ScrapLoot:FireServer("Junk") end
                if States.Hunger then ReplicatedStorage.ReduceHunger:FireServer(50) end
                
                -- ถ้าเป็นโหมดปกติ (ไม่ใช่เสี้ยววิ) ให้รอเล็กน้อยระหว่างคุ้ยครั้งที่ 1 และ 2
                if not States.UltraSpeed then task.wait(0.1) end
            end
            
            -- หลังจากคุ้ยไป 2 รอบแล้ว ค่อยขาย 1 รอบ (ถ้าเปิดขาย)
            if States.Sell then
                ReplicatedStorage.SellAllItems:FireServer()
            end
            
            if not States.UltraSpeed then break end
        end
    end
end)

-- ระบบลาก UI
uBtn.MouseButton1Click:Connect(function() menuFrame.Visible = not menuFrame.Visible end)
local d, ds, sp
uBtn.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then d = true ds = i.Position sp = uBtn.Position end end)
UserInputService.InputChanged:Connect(function(i) if d then 
    local del = i.Position - ds 
    uBtn.Position = UDim2.new(sp.X.Scale, sp.X.Offset + del.X, sp.Y.Scale, sp.Y.Offset + del.Y)
    menuFrame.Position = UDim2.new(sp.X.Scale, sp.X.Offset + del.X + 100, sp.Y.Scale, sp.Y.Offset + del.Y - 200)
end end)
uBtn.InputEnded:Connect(function() d = false end)
