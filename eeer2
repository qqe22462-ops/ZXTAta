local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local IsInvisible = false
local FakeChar = nil
local GhostHRP = nil

---------------------------------------------------------
-- [ ฟังก์ชันสลับร่างวิญญาณ ]
---------------------------------------------------------

local function ToggleInvis()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local realHRP = char.HumanoidRootPart
    local realHum = char:FindFirstChildOfClass("Humanoid")
    
    IsInvisible = not IsInvisible

    if IsInvisible then
        -- 1. สร้างร่างวิญญาณ (ก๊อปปี้จากตัวเราเป๊ะๆ)
        char.Archivable = true
        FakeChar = char:Clone()
        char.Archivable = false
        FakeChar.Name = "Pisit_GhostBody"
        FakeChar.Parent = workspace
        
        GhostHRP = FakeChar:FindFirstChild("HumanoidRootPart")
        local ghostHum = FakeChar:FindFirstChildOfClass("Humanoid")
        
        -- ปรับความใส (นิดเดียวตามสั่ง 0.4) และล็อคให้นิ่ง
        for _, part in pairs(FakeChar:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Transparency = 0.4
                part.CanCollide = false
                part.Anchored = true
            elseif part:IsA("Decal") then
                part.Transparency = 0.4
            end
        end

        -- 2. ย้ายตัวจริงไป "โคตรไกล" (2 แสนบล็อก) เพื่อกันโดนตี
        local originalCF = realHRP.CFrame
        realHRP.CFrame = CFrame.new(0, 200000, 0)
        realHRP.Anchored = true
        realHum.PlatformStand = true -- ทำให้ตัวจริงลอยนิ่งๆ ไม่ขยับ

        -- 3. ย้ายร่างวิญญาณมาไว้ที่จุดเดิม
        GhostHRP.CFrame = originalCF

        -- 4. ตั้งค่ากล้องให้เกาะร่างวิญญาณ (หมุนได้ปกติ)
        Camera.CameraSubject = ghostHum
        
        print("ล่องหน: ตัวจริงอยู่ปลอดภัยบนฟ้า 200,000 | กล้องหมุนได้ปกติ")
    else
        -- [[ ปิดระบบ - กลับคืนร่างเดิม ]]
        if FakeChar then
            local currentGhostPos = GhostHRP.CFrame
            FakeChar:Destroy()
            
            -- วาร์ปตัวจริงกลับมาที่จุดที่ร่างวิญญาณอยู่ล่าสุด
            realHRP.Anchored = false
            realHum.PlatformStand = false
            realHRP.CFrame = currentGhostPos
            
            -- คืนค่ากล้องให้ตัวจริง
            Camera.CameraSubject = realHum
        end
        print("ปรากฏตัว: กลับเข้าสู่ร่างจริง")
    end
end

---------------------------------------------------------
-- [ ระบบ UI ปุ่มสี่เหลี่ยมแดงลากได้ ]
---------------------------------------------------------

local sg = Instance.new("ScreenGui", LocalPlayer.PlayerGui)
sg.Name = "PisitGhostV3UI"; sg.ResetOnSpawn = false

local btn = Instance.new("TextButton", sg)
btn.Size = UDim2.new(0, 110, 0, 110)
btn.Position = UDim2.new(0.5, -55, 0.4, 0)
btn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
btn.Text = "ล่องหน\n(OFF)"
btn.TextColor3 = Color3.new(1, 1, 1); btn.Font = "SourceSansBold"; btn.TextSize = 18
Instance.new("UICorner", btn)

btn.MouseButton1Click:Connect(function()
    ToggleInvis()
    btn.Text = IsInvisible and "ล่องหน\n(ON)" or "ล่องหน\n(OFF)"
    btn.BackgroundColor3 = IsInvisible and Color3.fromRGB(0, 180, 0) or Color3.fromRGB(200, 0, 0)
end)

-- ระบบลาก UI แบบสมูท
local dragging, dragStart, startPos
btn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = btn.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input) dragging = false end)
