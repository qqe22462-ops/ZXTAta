local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TaskRemote = ReplicatedStorage:WaitForChild("TaskRemote")

local SpamActive = false
local SpectateActive = false
local ESPActive = false

-- [[ สร้าง UI เมนูหลัก ]]
local sg = Instance.new("ScreenGui", LocalPlayer.PlayerGui)
sg.Name = "PisitU_Menu_V16"
sg.ResetOnSpawn = false

-- ปุ่มตัว U
local uBtn = Instance.new("TextButton", sg)
uBtn.Size = UDim2.new(0, 50, 0, 50)
uBtn.Position = UDim2.new(0, 10, 0.5, -25)
uBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
