-- [[ ᴘɪꜱɪᴛ  ᴀᴜᴛᴏ-ᴄʜᴇꜱᴛ  ᴠ7  (ꜰɪxᴇᴅ) ]]
-- เน้นล็อคเฉพาะ "กล่องอัญมณี" ไม่เก็บคริสตัลม่วง

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local IsActive = false
local Radius = 50 

-- [[ สร้าง UI ]]
local sg = Instance.new("ScreenGui", LocalPlayer.PlayerGui)
sg.Name = "PisitChestV7"
sg.ResetOnSpawn = false

local main = Instance.new("Frame", sg)
main.Size = UDim2.new(0, 220, 0, 160)
main.Position = UDim2.new(0.5, -110, 0.2, 0)
main.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
main.Active = true
Instance.new("UICorner", main)

-- ปุ่มเปิด/ปิด
local toggleBtn = Instance.new("TextButton", main)
toggleBtn.Size = UDim2.new(0, 180, 0, 40)
toggleBtn.Position = UDim2.new(0.5, -90, 0.15, 0)
toggleBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
toggleBtn.Text = "เปิดกล่อง: OFF"
toggleBtn.TextColor3 = Color3.new(1, 1, 1)
toggleBtn.Font = "SourceSansBold"
toggleBtn.TextSize = 18
Instance.new("UICorner", toggleBtn)

-- Slider รัศมี
local sliderFrame = Instance.new("Frame", main)
sliderFrame.Size = UDim2.new(0, 180, 0, 8)
sliderFrame.Position = UDim2.new(0.5, -90, 0.65, 0)
sliderFrame.BackgroundColor3 = Color3.fromRGB(50, 50, 50)

local sliderDot = Instance.new("TextButton", sliderFrame)
sliderDot.Size = UDim2.new(0, 20, 0, 20)
sliderDot.Position = UDim2.new(0.5, -10, 0.5, -10)
sliderDot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
sliderDot.Text = ""
Instance.new("UICorner", sliderDot)

local radiusLabel = Instance.new("TextLabel", main)
radiusLabel.Size = UDim2.new(1, 0, 0, 20)
radiusLabel.Position = UDim2.new(0, 0, 0.78, 0)
radiusLabel.BackgroundTransparency = 1
radiusLabel.Text = "ระยะเก็บ: 50"
radiusLabel.TextColor3 = Color3.new(1, 1, 1)
radiusLabel.Font = "SourceSansBold"

-- [[ สร้างวงกลมแดงแจ้งเตือนรัศมี (Visualizer) ]]
local visualPart = Instance.new("Part")
visualPart.Name = "PisitRadiusCircle"
visualPart.Shape = Enum.PartType.Cylinder
visualPart.Size = Vector3.new(0.2, Radius * 2, Radius * 2)
visualPart.Color = Color3.fromRGB(255, 0, 0)
visualPart.Transparency = 0.8
visualPart.Material = Enum.Material.ForceField
visualPart.CanCollide = false
visualPart.Anchored = true
visualPart.Rotation = Vector3.new(0, 0, 90)
visualPart.Parent = workspace

---------------------------------------------------------
-- [ ระบบคำสั่ง ]
---------------------------------------------------------

-- 1. ระบบ Slider ปรับระยะ 1-100
local draggingSlider = false
sliderDot.MouseButton1Down:Connect(function() draggingSlider = true end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then draggingSlider = false end end)

UserInputService.InputChanged:Connect(function(input)
	if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local mouseX = input.Position.X
		local sliderX = sliderFrame.AbsolutePosition.X
		local sliderWidth = sliderFrame.AbsoluteSize.X
		local percent = math.clamp((mouseX - sliderX) / sliderWidth, 0, 1)
		
		sliderDot.Position = UDim2.new(percent, -10, 0.5, -10)
		Radius = math.floor(percent * 100)
		if Radius < 1 then Radius = 1 end
		radiusLabel.Text = "ระยะเก็บ: " .. Radius
		visualPart.Size = Vector3.new(0.2, Radius * 2, Radius * 2)
	end
end)

-- 2. ปุ่มเปิด/ปิดการทำงาน
toggleBtn.MouseButton1Click:Connect(function()
	IsActive = not IsActive
	if IsActive then
		toggleBtn.Text = "เปิดกล่อง: ON"
		toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
	else
		toggleBtn.Text = "เปิดกล่อง: OFF"
		toggleBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
	end
end)

-- 3. ลูปการทำงานหลัก (Check เฉพาะกล่องอัญมณี)
RunService.RenderStepped:Connect(function()
	local char = LocalPlayer.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	
	if hrp then
		-- เลื่อนวงกลมตามตัวละคร
		visualPart.Position = hrp.Position - Vector3.new(0, 2.8, 0)
		
		if IsActive then
			-- ค้นหาของในระยะ
			for _, item in pairs(workspace:GetDescendants()) do
				-- [จุดสำคัญ] เช็คชื่อว่าต้องเป็น "กล่องอัญมณี" เท่านั้น
				if item:IsA("ProximityPrompt") then
					-- ตรวจสอบ Object พ่อแม่ หรือตัวมันเองว่ามีคำว่า "กล่องอัญมณี" ไหม
					local parentName = item.Parent.Name
					local objectTitle = item.ObjectText -- ข้อความบนปุ่ม (เช่น "กล่องอัญมณี")
					
					if parentName == "กล่องอัญมณี" or objectTitle == "กล่องอัญมณี" then
						local distance = (hrp.Position - item.Parent:GetPivot().Position).Magnitude
						
						if distance <= Radius then
							-- กดปุ่มเก็บทันที
							fireproximityprompt(item)
						end
					end
				end
			end
		end
	end
end)

-- 4. ระบบลาก UI
local dragging, dragStart, startPos
main.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true; dragStart = input.Position; startPos = main.Position
	end
end)
UserInputService.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart
		main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)
UserInputService.InputEnded:Connect(function() dragging = false end)
