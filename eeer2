-- OWNER: ไกรสร พิสิษฐ์ 🫡
-- ระบบ: กดเลือกชื่อจากลิสต์ + เซฟจุดเดิมอัตโนมัติ

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")

local LastPos = nil -- เก็บพิกัดเดิม
local ListVisible = false -- สถานะการเปิด/ปิดลิสต์ชื่อ

-- [[ สร้าง UI หลัก ]]
local sg = Instance.new("ScreenGui", LocalPlayer.PlayerGui)
sg.Name = "PisitSelectorUI"
sg.ResetOnSpawn = false

-- แถบเมนูหลัก (ลากได้)
local MainFrame = Instance.new("Frame", sg)
MainFrame.Size = UDim2.new(0, 150, 0, 100)
MainFrame.Position = UDim2.new(0.5, -75, 0.4, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.Active = true
Instance.new("UICorner", MainFrame)

-- ปุ่มเปิด/ปิด รายชื่อผู้เล่น
local toggleListBtn = Instance.new("TextButton", MainFrame)
toggleListBtn.Size = UDim2.new(0, 130, 0, 35)
toggleListBtn.Position = UDim2.new(0.5, -65, 0.1, 0)
toggleListBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
toggleListBtn.Text = "เลือกผู้เล่น 👥"
toggleListBtn.TextColor3 = Color3.new(1, 1, 1)
toggleListBtn.Font = "SourceSansBold"
Instance.new("UICorner", toggleListBtn)

-- ปุ่มวาร์ปกลับจุดเดิม
local backBtn = Instance.new("TextButton", MainFrame)
backBtn.Size = UDim2.new(0, 130, 0, 35)
backBtn.Position = UDim2.new(0.5, -65, 0.55, 0)
backBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
backBtn.Text = "กลับจุดเดิม (BACK)"
backBtn.TextColor3 = Color3.new(1, 1, 1)
backBtn.Font = "SourceSansBold"
Instance.new("UICorner", backBtn)

-- [[ สร้าง ScrollingFrame สำหรับรายชื่อผู้เล่น (อยู่ข้างๆ แถบหลัก) ]]
local PlayerListFrame = Instance.new("ScrollingFrame", MainFrame)
PlayerListFrame.Size = UDim2.new(0, 150, 0, 200)
PlayerListFrame.Position = UDim2.new(1.1, 0, 0, 0) -- เด้งออกไปทางขวา
PlayerListFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
PlayerListFrame.Visible = false
PlayerListFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
PlayerListFrame.ScrollBarThickness = 5
Instance.new("UICorner", PlayerListFrame)
local listLayout = Instance.new("UIListLayout", PlayerListFrame)
listLayout.Padding = UDim.new(0, 5)

---------------------------------------------------------
-- [ ฟังก์ชันการทำงาน ]
---------------------------------------------------------

-- 1. ฟังก์ชันอัปเดตรายชื่อผู้เล่น
local function UpdatePlayerList()
    -- ลบปุ่มชื่อเก่าออกก่อน
    for _, child in pairs(PlayerListFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    -- สร้างปุ่มใหม่ตามจำนวนคนในเซิร์ฟ
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local pBtn = Instance.new("TextButton", PlayerListFrame)
            pBtn.Size = UDim2.new(1, -10, 0, 30)
            pBtn.BackgroundColor3 = Color3.fromRGB(100, 40, 40) -- สีแดง
            pBtn.Text = p.DisplayName -- แสดงชื่อเล่น (Display Name)
            pBtn.TextColor3 = Color3.new(1, 1, 1)
            pBtn.Font = "SourceSans"
            pBtn.TextSize = 14
            Instance.new("UICorner", pBtn)
            
            -- เมื่อคลิกชื่อคนนั้น
            pBtn.MouseButton1Click:Connect(function()
                local char = LocalPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    LastPos = char.HumanoidRootPart.CFrame -- เซฟจุดเดิม
                    char.HumanoidRootPart.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0, 3, 0) -- วาร์ปไปหา
                    print("วาร์ปไปหา: " .. p.Name)
                end
            end)
            
            PlayerListFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y)
        end
    end
end

-- 2. เปิด/ปิดลิสต์รายชื่อ
toggleListBtn.MouseButton1Click:Connect(function()
    ListVisible = not ListVisible
    PlayerListFrame.Visible = ListVisible
    if ListVisible then UpdatePlayerList() end -- อัปเดตชื่อทุกครั้งที่เปิด
end)

-- 3. วาร์ปกลับจุดเดิม
backBtn.MouseButton1Click:Connect(function()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") and LastPos then
        char.HumanoidRootPart.CFrame = LastPos
        print("กลับจุดเดิมแล้ว")
    end
end)

---------------------------------------------------------
-- [ ระบบลาก UI ทั้งแผง ]
---------------------------------------------------------
local dragging, dragStart, startPos
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = MainFrame.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input) dragging = false end)
