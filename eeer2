mainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
mainFrame.Visible = false
Instance.new("UICorner", mainFrame)

local function CreateMenuBtn(text, pos, color)
    local b = Instance.new("TextButton", mainFrame)
    b.Size = UDim2.new(0, 180, 0, 50)
    b.Position = pos
    b.BackgroundColor3 = color
    b.Text = text
    b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = "SourceSansBold"
    Instance.new("UICorner", b)
    return b
end

local spamBtn = CreateMenuBtn("สแปมเศษเงิน: OFF", UDim2.new(0.5, -90, 0.05, 0), Color3.fromRGB(150, 0, 0))
local stickBtn = CreateMenuBtn("สิงวิญญาณคนใกล้", UDim2.new(0.5, -90, 0.38, 0), Color3.fromRGB(0, 100, 200))
local espBtn = CreateMenuBtn("เปิดมองทะลุ: OFF", UDim2.new(0.5, -90, 0.71, 0), Color3.fromRGB(100, 0, 150))

---------------------------------------------------------
-- [ ฟังก์ชันที่ 3: ระบบ ESP + HP ]
---------------------------------------------------------

local function CreateESP(player)
    local highlight = Instance.new("Highlight")
    highlight.Name = "PisitESP"
    highlight.Adornee = player.Character
    highlight.FillColor = Color3.fromRGB(255, 0, 0)
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = Color3.new(1, 1, 1)
    highlight.Parent = player.Character

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "PisitHP"
    billboard.Adornee = player.Character:WaitForChild("Head")
    billboard.Size = UDim2.new(0, 100, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = player.Character

    local hpLabel = Instance.new("TextLabel", billboard)
    hpLabel.Size = UDim2.new(1, 0, 1, 0)
    hpLabel.BackgroundTransparency = 1
    hpLabel.TextColor3 = Color3.new(0, 1, 0)
    hpLabel.Font = "SourceSansBold"
    hpLabel.TextSize = 14

    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not ESPActive or not player.Character or not player.Character:FindFirstChild("Humanoid") then
            highlight:Destroy()
            billboard:Destroy()
            connection:Disconnect()
        else
            local hp = math.floor(player.Character.Humanoid.Health)
            hpLabel.Text = player.Name .. "\nHP: " .. hp
            if hp < 50 then hpLabel.TextColor3 = Color3.new(1, 1, 0) end
            if hp < 25 then hpLabel.TextColor3 = Color3.new(1, 0, 0) end
        end
    end)
end

espBtn.MouseButton1Click:Connect(function()
    ESPActive = not ESPActive
    espBtn.Text = ESPActive and "เปิดมองทะลุ: ON" or "เปิดมองทะลุ: OFF"
    espBtn.BackgroundColor3 = ESPActive and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(100, 0, 150))
    
    if ESPActive then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then CreateESP(p) end
        end
        Players.PlayerAdded:Connect(function(p)
            p.CharacterAdded:Connect(function(char) if ESPActive then task.wait(0.5) CreateESP(p) end end)
        end)
    end
end)

---------------------------------------------------------
-- [ ฟังก์ชัน 1 & 2 (เหมือนเดิมแต่ปรับปรุงความเสถียร) ]
---------------------------------------------------------

spamBtn.MouseButton1Click:Connect(function()
    SpamActive = not SpamActive
    spamBtn.Text = SpamActive and "สแปมเศษเงิน: ON" or "สแปมเศษเงิน: OFF"
    spamBtn.BackgroundColor3 = SpamActive and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
    if SpamActive then
        task.spawn(function()
            while SpamActive do
                TaskRemote:FireServer(true)
                RunService.Heartbeat:Wait()
            end
        end)
    end
end)

stickBtn.MouseButton1Click:Connect(function()
    local target = nil
    local dist = math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (LocalPlayer.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d target = p end
        end
    end
    
    if target and not SpectateActive then
        SpectateActive = true
        local hrp = LocalPlayer.Character.HumanoidRootPart
        local oldPos = hrp.CFrame
        local con = RunService.Heartbeat:Connect(function()
            if target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                hrp.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 2)
            end
        end)
        task.wait(2)
        con:Disconnect()
        hrp.CFrame = oldPos
        SpectateActive = false
    end
end)

-- ระบบ UI (ลากได้/เปิดปิด)
uBtn.MouseButton1Click:Connect(function() mainFrame.Visible = not mainFrame.Visible end)
local d, ds, sp
uBtn.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then d = true ds = i.Position sp = uBtn.Position end end)
game:GetService("UserInputService").InputChanged:Connect(function(i) if d then 
    local del = i.Position - ds 
    uBtn.Position = UDim2.new(sp.X.Scale, sp.X.Offset + del.X, sp.Y.Scale, sp.Y.Offset + del.Y)
    mainFrame.Position = UDim2.new(sp.X.Scale, sp.X.Offset + del.X + 60, sp.Y.Scale, sp.Y.Offset + del.Y - 40)
end end)
uBtn.InputEnded:Connect(function() d = false end)

