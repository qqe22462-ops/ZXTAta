-- [[ ฟังก์ชันสร้างปุ่ม ]]
local function CreateBtn(name, pos, key)
    local btn = Instance.new("TextButton", menuFrame)
    btn.Size = UDim2.new(0, 270, 0, 60)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
    btn.Text = name .. ": OFF"
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 24 -- ตัวหนังสือใหญ่สะใจ
    Instance.new("UICorner", btn)
    
    btn.MouseButton1Click:Connect(function()
        if (key == "Trash" and States.Present) or (key == "Present" and States.Trash) then return end
        
        if key == "UltraSpeed" and not States.UltraSpeed then
            warnFrame.Visible = true
        else
            States[key] = not States[key]
            btn.Text = name .. (States[key] and ": ON" or ": OFF")
            btn.BackgroundColor3 = States[key] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
        end
    end)
    return btn
end

