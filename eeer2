-- OWNER: ไกรสร พิสิษฐ์ 🫡
-- ความเร็ว: ระดับสูงสุด (Instant Trigger)

local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local PlaceId = game.PlaceId
local JobId = game.JobId -- ล็อค ID เซิร์ฟเวอร์ปัจจุบันไว้ก่อนเลย

-- สร้างปุ่มกดหนี (สีเขียวสว่าง)
local sg = Instance.new("ScreenGui", LocalPlayer.PlayerGui)
sg.Name = "FastEscape"

local btn = Instance.new("TextButton", sg)
btn.Size = UDim2.new(0, 140, 0, 60)
btn.Position = UDim2.new(0.5, -70, 0.15, 0)
btn.BackgroundColor3 = Color3.fromRGB(0, 255, 100) -- เขียวสว่างเห็นชัด
btn.Text = "หนี (เซิร์ฟเดิม)"
btn.TextColor3 = Color3.new(0, 0, 0)
btn.Font = "SourceSansBold"
btn.TextSize = 22
Instance.new("UICorner", btn)

-- [ จังหวะหนี ]
-- ใช้ InputBegan (แค่แตะโดนปุ๊บ วาร์ปปั๊บ ไม่ต้องรอนิ้วยกออก)
btn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        -- สั่ง Teleport กลับเซิร์ฟเวอร์เดิมทันที
        TeleportService:TeleportToPlaceInstance(PlaceId, JobId, LocalPlayer)
    end
end)

-- ระบบลาก (เผื่อจะย้ายปุ่มไปจุดที่นิ้วกดถนัดที่สุด)
local dragging, dragStart, startPos
btn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = btn.Position
    end
end)
game:GetService("UserInputService").InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
btn.InputEnded:Connect(function(input) dragging = false end)
