local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

local IsInvisible = false
local FakeChar = nil
local RealHRP = nil
local RemoteCam = nil

---------------------------------------------------------
-- [ ฟังก์ชันล่องหน (Ghost Logic) ]
---------------------------------------------------------

local function ToggleInvis()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    RealHRP = char.HumanoidRootPart
    local hum = char:FindFirstChildOfClass("Humanoid")

    IsInvisible = not IsInvisible

    if IsInvisible then
        -- 1. สร้างร่างวิญญาณจำลอง
        char.Archivable = true
        FakeChar = char:Clone()
        char.Archivable = false
        FakeChar.Parent = workspace
        
        -- ปรับให้โปร่งใสนิดๆ เหมือนวิญญาณ
        for _, part in pairs(FakeChar:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Transparency = 0.5
                part.CanCollide = false
            elseif part:IsA("Decal") then
                part.Transparency = 0.5
            end
        end
        
        -- 2. วาร์ปตัวจริงไปโคตรไกล (สูง 5 หมื่นบล็อก)
        local originalPos = RealHRP.CFrame
        RealHRP.CFrame = CFrame.new(0, 50000, 0)
        RealHRP.Anchored = true -- ล็อคตัวจริงไว้บนฟ้า
        
        -- 3. ล็อคกล้องไว้ที่ร่างวิญญาณ
        workspace.CurrentCamera.CameraSubject = FakeChar:FindFirstChildOfClass("Humanoid")
        
        -- 4. ระบบบังคับร่างวิญญาณ (เดินตามจริง)
        _G.GhostLoop = RunService.RenderStepped:Connect(function()
            if FakeChar and hum then
                local moveDir = hum.MoveDirection
                FakeChar:FindFirstChildOfClass("Humanoid"):Move(moveDir, false)
                
                -- ถ้ากดกระโดด
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                    FakeChar:FindFirstChildOfClass("Humanoid").Jump = true
                end
            end
        end)
        
        print("สถานะ: ล่องหน (ตัวจริงอยู่บนฟ้า 50,000)")
    else
        -- [[ ปิดระบบ - กลับร่างเดิม ]]
        if _G.GhostLoop then _G.GhostLoop:Disconnect() end
        if FakeChar then FakeChar:Destroy() end
        
        RealHRP.Anchored = false
        RealHRP.CFrame = FakeChar and FakeChar.PrimaryPart and FakeChar.PrimaryPart.CFrame or RealHRP.CFrame
        workspace.CurrentCamera.CameraSubject = hum
        
        print("สถานะ: ปรากฏตัว")
    end
end

---------------------------------------------------------
-- [ ระบบ UI ปุ่มแดงลากได้ ]
---------------------------------------------------------

local sg = Instance.new("ScreenGui", LocalPlayer.PlayerGui)
sg.Name = "PisitInvisUI"
sg.ResetOnSpawn = false

local btn = Instance.new("TextButton", sg)
btn.Name = "InvisBtn"
btn.Size = UDim2.new(0, 100, 0, 100)
btn.Position = UDim2.new(0.5, -50, 0.4, 0)
btn.BackgroundColor3 = Color3.fromRGB(200, 0, 0) -- สีแดงตามสั่ง
btn.Text = "ล่องหน\n(OFF)"
btn.TextColor3 = Color3.new(1, 1, 1)
btn.Font = "SourceSansBold"
btn.TextSize = 18
Instance.new("UICorner", btn)

-- ระบบเปิด/ปิด
btn.MouseButton1Click:Connect(function()
    ToggleInvis()
    if IsInvisible then
        btn.Text = "ล่องหน\n(ON)"
        btn.BackgroundColor3 = Color3.fromRGB(0, 150, 0) -- เปลี่ยนเป็นเขียวเมื่อเปิด
    else
        btn.Text = "ล่องหน\n(OFF)"
        btn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    end
end)

-- ระบบลาก UI (Draggable)
local dragging, dragInput, dragStart, startPos
btn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = btn.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input) dragging = false end)
