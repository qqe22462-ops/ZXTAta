local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

local AbilityEnabled = false
local ESPEnabled = false
local SpectateEnabled = false
local TargetPlayer = nil

---------------------------------------------------------
-- [ ระบบสิงร่าง & Auto Ability ]
---------------------------------------------------------
RunService.Stepped:Connect(function()
    if SpectateEnabled and TargetPlayer and TargetPlayer.Character then
        local targetHRP = TargetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if targetHRP and myHRP then
            myHRP.CFrame = targetHRP.CFrame
            myHRP.Velocity = Vector3.new(0,0,0)
        end
    end
end)

task.spawn(function()
    while true do
        if AbilityEnabled then
            pcall(function() ReplicatedStorage.Communication.AbilityEffect:FireServer("CrowdAbility") end)
        end
        task.wait(0.5)
    end
end)

