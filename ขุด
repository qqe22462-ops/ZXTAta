local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- ตั้งค่าตัวแปร
local walkSpeedActive = true
local normalSpeed = 16
local fastSpeed = 100
local toggleKey = Enum.KeyCode.P

-- ฟังก์ชันสำหรับอัปเดตความเร็ว
local function updateSpeed()
    local character = player.Character or player.CharacterAdded:Wait()
    local humanoid = character:WaitForChild("Humanoid")
    
    if walkSpeedActive then
        humanoid.WalkSpeed = fastSpeed
    else
        humanoid.WalkSpeed = normalSpeed
    end
end

-- ตรวจจับการกดปุ่มบน Keyboard
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end -- ป้องกันการทำงานขณะพิมพ์ในช่อง Chat
    
    if input.KeyCode == toggleKey then
        walkSpeedActive = not walkSpeedActive
        updateSpeed()
        
        -- แจ้งเตือนสถานะ (เลือกเปิดหรือปิดได้)
        print("WalkSpeed Status: " .. (walkSpeedActive and "ON" or "OFF"))
    end
end)

-- ทำให้ตัวละครวิ่งเร็วทันทีเมื่อรัน Script ครั้งแรก
updateSpeed()

-- ป้องกันความเร็วคืนค่าเดิมเมื่อตัวละคร Reset (ตายแล้วเกิดใหม่)
player.CharacterAdded:Connect(function()
    task.wait(1) -- รอให้ตัวละครโหลดเสร็จเล็กน้อย
    updateSpeed()
end)
