local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local humanoid = char:WaitForChild("Humanoid")

humanoid.UseJumpPower = true

local defaultSpeed = 16
local fastSpeed = 100
local isfast, isinvis, isInfJump, isGod, isNoclip = false, false, false, false, false

local screenGui = Instance.new("ScreenGui", player.PlayerGui)
screenGui.Name = "MySecretMenu"
screenGui.ResetOnSpawn = false

-- [[ ปุ่มเปิด/ปิดเมนู ]]
local toggleBtn = Instance.new("TextButton", screenGui)
toggleBtn.Size = UDim2.new(0, 80, 0, 35)
toggleBtn.Position = UDim2.new(0, 10, 0, 10)
toggleBtn.Text = "☰ เมนู"
toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 255)
toggleBtn.TextColor3 = Color3.new(1, 1, 1)
toggleBtn.BorderSizePixel = 0
toggleBtn.ZIndex = 10

-- [[ กรอบเมนูหลัก ]]
local menu = Instance.new("Frame", screenGui)
menu.Size = UDim2.new(0, 180, 0, 320)
menu.Position = UDim2.new(0, 10, 0, 55)
menu.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
menu.BackgroundTransparency = 0.2
menu.Visible = false
Instance.new("UICorner", menu).CornerRadius = UDim.new(0, 10)

-- หัวข้อ (ใช้สำหรับลาก)
local title = Instance.new("TextLabel", menu)
title.Size = UDim2.new(1, 0, 0, 40)
title.Text = "⚡ HYPER MENU"
title.BackgroundColor3 = Color3.fromRGB(0, 100, 255)
title.TextColor3 = Color3.new(1, 1, 1)
title.Font = Enum.Font.GothamBold
title.TextSize = 14
local titleCorner = Instance.new("UICorner", title)
titleCorner.CornerRadius = UDim.new(0, 10)

-- ScrollingFrame
local scroll = Instance.new("ScrollingFrame", menu)
scroll.Size = UDim2.new(1, 0, 1, -45)
scroll.Position = UDim2.new(0, 0, 0, 45)
scroll.BackgroundTransparency = 1
scroll.ScrollBarThickness = 4
scroll.CanvasSize = UDim2.new(0, 0, 0, 450) -- เพิ่มพื้นที่ให้ปุ่มใหม่ๆ

local btnList = {
    {key="speed",   label="🏃 วิ่งเร็ว"},
    {key="invis",   label="👻 หายตัว"},
    {key="infjump", label="🦘 โดดไม่จำกัด"},
    {key="god",     label="🛡️ อมตะ"},
    {key="noclip",  label="👁️ ทะลุกำแพง"},
    {key="warp500", label="🚀 พุ่งดิ่ง 500m"}
}

local btnObjects = {}
for i, data in ipairs(btnList) do
    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(1, -20, 0, 45)
    btn.Position = UDim2.new(0, 10, 0, 10 + (i-1) * 55)
    btn.Text = data.label .. " : ปิด"
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 12
    Instance.new("UICorner", btn)
    btnObjects[data.key] = btn
end

-- [[ ระบบลากเมนู ]]
local dragging, dragStart, startPos
title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = menu.Position
    end
end)
UIS.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        menu.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputEnded:Connect(function() dragging = false end)

toggleBtn.MouseButton1Click:Connect(function() menu.Visible = not menu.Visible end)

-- [[ ฟังก์ชันการทำงาน ]]

-- 1. วิ่งเร็ว
btnObjects["speed"].MouseButton1Click:Connect(function()
    isfast = not isfast
    humanoid.WalkSpeed = isfast and fastSpeed or defaultSpeed
    btnObjects["speed"].Text = "🏃 วิ่งเร็ว : " .. (isfast and "เปิด ✅" or "ปิด")
    btnObjects["speed"].BackgroundColor3 = isfast and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(50, 50, 50)
end)

-- 2. หายตัว (เฉพาะเราเห็น หรือแมพที่ไม่กัน)
btnObjects["invis"].MouseButton1Click:Connect(function()
    isinvis = not isinvis
    for _, p in pairs(char:GetDescendants()) do
        if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
            p.Transparency = isinvis and 1 or 0
        end
    end
    btnObjects["invis"].Text = "👻 หายตัว : " .. (isinvis and "เปิด ✅" or "ปิด")
end)

-- 3. กระโดดไม่จำกัด
UIS.JumpRequest:Connect(function()
    if isInfJump then humanoid:ChangeState(Enum.HumanoidStateType.Jumping) end
end)
btnObjects["infjump"].MouseButton1Click:Connect(function()
    isInfJump = not isInfJump
    btnObjects["infjump"].Text = "🦘 โดดไม่จำกัด : " .. (isInfJump and "เปิด ✅" or "ปิด")
end)

-- 4. อมตะ (Simple God)
local godConn
btnObjects["god"].MouseButton1Click:Connect(function()
    isGod = not isGod
    if isGod then
        godConn = humanoid.HealthChanged:Connect(function() humanoid.Health = 100 end)
    elseif godConn then
        godConn:Disconnect()
    end
    btnObjects["god"].Text = "🛡️ อมตะ : " .. (isGod and "เปิด ✅" or "ปิด")
end)

-- 5. ทะลุกำแพง (Noclip)
RunService.Stepped:Connect(function()
    if isNoclip then
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end
end)
btnObjects["noclip"].MouseButton1Click:Connect(function()
    isNoclip = not isNoclip
    btnObjects["noclip"].Text = "👁️ ทะลุกำแพง : " .. (isNoclip and "เปิด ✅" or "ปิด")
end)

-- 6. วาร์ปดิ่งพฤกษา (500m -> 100m) ตามที่คุณขอ
local isWarping = false
btnObjects["warp500"].MouseButton1Click:Connect(function()
    if isWarping then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if root then
        isWarping = true
        local startY = root.Position.Y
        root.CFrame = root.CFrame * CFrame.new(0, 500, 0) -- วาร์ปขึ้น 500
        task.wait(0.2)
        
        local bv = Instance.new("BodyVelocity", root)
        bv.MaxForce = Vector3.new(0, math.huge, 0)
        bv.Velocity = Vector3.new(0, -1000, 0) -- ดิ่งลงความเร็วแสง
        
        local conn
        conn = RunService.Heartbeat:Connect(function()
            if root.Position.Y <= startY + 100 then -- ถึงระยะ 100 เมตร
                bv:Destroy()
                conn:Disconnect()
                isWarping = false
            end
        end)
    end
end)

print("สคริปต์แก้ไขสมบูรณ์แล้ว! ⚡")
