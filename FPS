-- [[ ᴘɪꜱɪᴛ  ᴜʟᴛʀᴀ  ᴀᴜᴛᴏ-ᴄʟɪᴄᴋᴇʀ ]]
-- OWNER: ไกรสร พิสิษฐ์ 🫡
-- ความเร็ว: 20ms (0.02 วินาที)

local LocalPlayer = game:GetService("Players").LocalPlayer
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local IsActive = false
local ClickInterval = 0.02 -- 20 มิลลิวินาที
local lastClick = 0

-- [[ สร้าง UI ]]
local sg = Instance.new("ScreenGui", LocalPlayer.PlayerGui)
sg.Name = "PisitAutoClickUI"
sg.ResetOnSpawn = false

-- ปุ่มออโต้คลิก (ลากได้)
local clickBtn = Instance.new("TextButton", sg)
clickBtn.Size = UDim2.new(0, 120, 0, 120) -- ทรงจัตุรัสเพื่อให้เห็นจุดที่จะคลิกชัดเจน
clickBtn.Position = UDim2.new(0.5, -60, 0.5, -60)
clickBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
clickBtn.BackgroundTransparency = 0.5 -- โปร่งแสงนิดนึงเพื่อให้เห็นว่าวางทับอะไรอยู่
clickBtn.Text = "OFF"
clickBtn.TextColor3 = Color3.new(1, 1, 1)
clickBtn.Font = "SourceSansBold"
clickBtn.TextSize = 25
clickBtn.Active = true
clickBtn.Draggable = true -- เปิดระบบลากพื้นฐาน
Instance.new("UICorner", clickBtn).CornerRadius = UDim.new(1, 0) -- ทำเป็นวงกลม

-- [[ ระบบการทำงาน ]]
clickBtn.MouseButton1Click:Connect(function()
    IsActive = not IsActive
    if IsActive then
        clickBtn.Text = "ON"
        clickBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
    else
        clickBtn.Text = "OFF"
        clickBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    end
end)

-- ระบบรัวคลิก (เช็คทุกเฟรม)
RunService.RenderStepped:Connect(function()
    if IsActive then
        local currentTime = tick()
        if currentTime - lastClick >= ClickInterval then
            lastClick = currentTime
            
            -- จำลองการคลิกโดยใช้ VirtualInputManager (ทำงานได้แม่นยำที่สุด)
            local vim = game:GetService("VirtualInputManager")
            vim:SendMouseButtonEvent(clickBtn.AbsolutePosition.X + (clickBtn.AbsoluteSize.X / 2), clickBtn.AbsolutePosition.Y + (clickBtn.AbsoluteSize.Y / 2) + 36, 0, true, game, 1)
            vim:SendMouseButtonEvent(clickBtn.AbsolutePosition.X + (clickBtn.AbsoluteSize.X / 2), clickBtn.AbsolutePosition.Y + (clickBtn.AbsoluteSize.Y / 2) + 36, 0, false, game, 1)
        end
    end
end)

-- [[ ระบบลาก UI (เพื่อให้เสถียรทั้งในคอมและมือถือ) ]]
local dragging, dragStart, startPos
clickBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = clickBtn.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        clickBtn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function() dragging = false end)
