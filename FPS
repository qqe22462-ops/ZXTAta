-- [[ ᴘɪꜱɪᴛ  ᴄᴇɴᴛᴇʀ  ᴀꜰᴋ  ᴄʟɪᴄᴋᴇʀ  ᴠ13 ]]
-- ระบบรัวคลิกกลางหน้าจออัตโนมัติ (20ms)
-- ออกแบบมาเพื่อการ AFK โดยเฉพาะ

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local VIM = game:GetService("VirtualInputManager")

local IsActive = false
local ClickInterval = 0.02 -- ความเร็ว 20 มิลลิวินาที

-- [[ สร้าง UI ปุ่มเปิด/ปิด ]]
local sg = Instance.new("ScreenGui", LocalPlayer.PlayerGui)
sg.Name = "PisitCenterClicker_V13"
sg.ResetOnSpawn = false
sg.DisplayOrder = 1000

local toggleBtn = Instance.new("TextButton", sg)
toggleBtn.Size = UDim2.new(0, 150, 0, 50)
toggleBtn.Position = UDim2.new(0.1, 0, 0.5, 0)
toggleBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
toggleBtn.Text = "เริ่ม AFK: OFF"
toggleBtn.TextColor3 = Color3.new(1, 1, 1)
toggleBtn.Font = "SourceSansBold"
toggleBtn.TextSize = 18
Instance.new("UICorner", toggleBtn)

-- [[ ระบบการคลิกกลางหน้าจอ ]]
local lastClick = 0
RunService.Heartbeat:Connect(function()
    if IsActive then
        local now = tick()
        if now - lastClick >= ClickInterval then
            lastClick = now
            
            -- คำนวณจุดกึ่งกลางหน้าจอ
            local cam = workspace.CurrentCamera
            local centerX = cam.ViewportSize.X / 2
            local centerY = cam.ViewportSize.Y / 2
            
            -- ส่งคำสั่งคลิกไปที่กลางจอ
            VIM:SendMouseButtonEvent(centerX, centerY, 0, true, game, 1)
            VIM:SendMouseButtonEvent(centerX, centerY, 0, false, game, 1)
        end
    end
end)

-- [[ ระบบปุ่มควบคุม ]]
toggleBtn.MouseButton1Click:Connect(function()
    IsActive = not IsActive
    if IsActive then
        toggleBtn.Text = "เริ่ม AFK: ON"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
    else
        toggleBtn.Text = "เริ่ม AFK: OFF"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
    end
end)

-- [[ ระบบลากปุ่ม (Drag) ]]
local dragging, dragStart, startPos
toggleBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = toggleBtn.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        toggleBtn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function() dragging = false end)
