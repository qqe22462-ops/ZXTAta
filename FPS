---------------------------------------------------------
-- [ ระบบการทำงาน ]
---------------------------------------------------------

axeBtn.MouseButton1Click:Connect(function()
    States.AutoAxe = not States.AutoAxe
    axeBtn.Text = "ตัดไม้: " .. (States.AutoAxe and "ON" or "OFF")
    axeBtn.BackgroundColor3 = States.AutoAxe and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
end)

task.spawn(function()
    while true do
        if States.AutoAxe then
            local remote = GetRemote("AxeSwing")
            if remote then 
                remote:FireServer() 
            end
        end
        task.wait(0.1)
    end
end)

giftBtn.MouseButton1Click:Connect(function()
    local targetName = nameBox.Text
    local targetPlayer = Players:FindFirstChild(targetName)
    
    if targetPlayer then
        giftBtn.Text = "กำลังส่ง..."
        local remote = GetRemote("Gift")
        if remote and remote:IsA("RemoteFunction") then
            task.spawn(function() remote:InvokeServer(targetPlayer) end)
            giftBtn.Text = "ส่งสำเร็จ!"
        elseif remote and remote:IsA("RemoteEvent") then
            remote:FireServer(targetPlayer)
            giftBtn.Text = "ส่งสำเร็จ!"
        end
        task.wait(1)
        giftBtn.Text = "ส่งของขวัญ"
    else
        giftBtn.Text = "ไม่พบชื่อ!"
        task.wait(1)
        giftBtn.Text = "ส่งของขวัญ"
    end
end)

---------------------------------------------------------
-- [ ระบบปุ่ม K และลาก ]
---------------------------------------------------------

kBtn.MouseButton1Click:Connect(function()
    mainFrame.Visible = not mainFrame.Visible
end)

local dragging, dragStart, startPos
kBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = kBtn.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        local newPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        kBtn.Position = newPos
        mainFrame.Position = UDim2.new(newPos.X.Scale, newPos.X.Offset + 100, newPos.Y.Scale, newPos.Y.Offset - 135)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)
