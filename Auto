local function spawnTextRain()
    local rainGui = Instance.new("ScreenGui", player.PlayerGui); rainGui.Name = "PisitRainGui"; rainGui.ResetOnSpawn = false
    local active = true
    task.delay(10, function() active = false; wait(3); if rainGui then rainGui:Destroy() end end)
    task.spawn(function()
        while active do
            local txt = Instance.new("TextLabel", rainGui)
            txt.Size = UDim2.new(0, 200, 0, 30); txt.Position = UDim2.new(math.random(), 0, -0.1, 0)
            txt.BackgroundTransparency = 1; txt.Text = "เขาเป็นผู้สร้างสคริป"; txt.TextColor3 = Color3.fromRGB(255, 0, 0)
            txt.TextScaled = true; txt.Font = "SourceSansBold"; Instance.new("UIStroke", txt).Thickness = 2
            txt:TweenPosition(UDim2.new(txt.Position.X.Scale, 0, 1.1, 0), "In", "Linear", 2, true, function() txt:Destroy() end)
            task.wait(0.3)
        end
    end)
    task.spawn(function()
        while active do
            local txt = Instance.new("TextLabel", rainGui)
            txt.Size = UDim2.new(0, 250, 0, 30); txt.Position = UDim2.new(math.random(), 0, -0.1, 0)
            txt.BackgroundTransparency = 1; txt.Text = "ระวังโดนเตะออกจากเซิฟนะ"; txt.TextColor3 = Color3.fromRGB(0, 255, 0)
            txt.TextScaled = true; txt.Font = "SourceSansBold"; Instance.new("UIStroke", txt).Thickness = 2
            txt:TweenPosition(UDim2.new(txt.Position.X.Scale, 0, 1.1, 0), "In", "Linear", 4, true, function() txt:Destroy() end)
            task.wait(0.6)
        end
    end)
end

local function showWarning()
    local warnGui = Instance.new("ScreenGui", player.PlayerGui); warnGui.Name = "PisitWarning"; warnGui.ResetOnSpawn = false
    local txt = Instance.new("TextLabel", warnGui)
    txt.Size = UDim2.new(1, 0, 0.2, 0); txt.Position = UDim2.new(0, 0, 0.4, 0); txt.BackgroundTransparency = 1
    txt.Text = "คนนี้เป็นคนสร้างสคริปไม่สามารถล็อคเป้าได้ เขาคนนั้นชื่อ asasaafafe"; txt.TextScaled = true; txt.Font = "SourceSansBold"
    Instance.new("UIStroke", txt).Thickness = 3
    if clickCount <= 7 then txt.TextColor3 = Color3.fromRGB(0, 255, 0)
    elseif clickCount >= 8 and clickCount < 10 then txt.TextColor3 = Color3.fromRGB(255, 0, 0)
    elseif clickCount == 10 then spawnTextRain()
        task.spawn(function() while txt.Parent do for i=0,1,0.02 do if not txt.Parent then break end txt.TextColor3=Color3.fromHSV(i,1,1); task.wait(0.02) end end end)
    end
    task.wait(5); if warnGui then warnGui:Destroy() end
end

