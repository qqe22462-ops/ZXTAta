local function sendAttack(goalType)
    local char = player.Character
    if char and char:FindFirstChild("Communicate") then
        char.Communicate:FireServer({{Goal = goalType, Mobile = true}})
    end
end

local function applyRainbowEffect(obj)
    task.spawn(function()
        while obj and obj.Parent do
            for i = 0, 1, 0.01 do
                if not obj or not obj.Parent then break end
                obj.BackgroundColor3 = Color3.fromHSV(i, 0.7, 1); task.wait(0.03)
            end
        end
    end)
end

local function updatePlayerList()
    for _, item in pairs(scroll:GetChildren()) do if not item:IsA("UIListLayout") then item:Destroy() end end
    
    local headerText = Instance.new("TextLabel", scroll)
    headerText.Size = UDim2.new(1, -10, 0, 45); headerText.BackgroundTransparency = 1
    headerText.Text = "ไอ้ไก่ไม่มีปัญญาเล่นเลื่อกชื่อ😱"; headerText.TextColor3 = Color3.fromRGB(255, 255, 0); headerText.TextScaled = true

    local npcBtn = Instance.new("TextButton", scroll)
    npcBtn.Size = UDim2.new(1, -10, 0, 45); npcBtn.Text = "NPC กากๆสัส🤣"
    npcBtn.TextColor3 = Color3.new(1, 1, 1); npcBtn.TextScaled = true; Instance.new("UICorner", npcBtn)
    applyRainbowEffect(npcBtn)
    npcBtn.MouseButton1Click:Connect(function() selectedTargetObj = workspace:FindFirstChild("Weakest Dummy", true); toggleBtn.Text = "TARGET: NPC 🤣" end)

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then
            local pBtn = Instance.new("TextButton", scroll)
            pBtn.Size = UDim2.new(1, -10, 0, 45); pBtn.Text = p.DisplayName
            pBtn.BackgroundColor3 = (selectedTargetObj == p) and Color3.fromRGB(0, 100, 200) or Color3.fromRGB(45, 45, 45)
            pBtn.TextColor3 = (selectedTargetObj == p) and Color3.fromRGB(0, 255, 255) or Color3.new(1, 1, 1)
            pBtn.TextScaled = true; Instance.new("UICorner", pBtn)
            pBtn.MouseButton1Click:Connect(function() selectedTargetObj = p; updatePlayerList() end)
        end
    end
end
task.spawn(function() while task.wait(2) do updatePlayerList() end end)

-- [[ 3. ระบบวาร์ปล็อคเป้าหมาย (ปรับเป็น 30 เมตร) ]]
RunService.Heartbeat:Connect(function()
    if not selectedTargetObj then return end
    local targetChar = (selectedTargetObj:IsA("Player") and selectedTargetObj.Character) or selectedTargetObj
    local myHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    
    if targetChar and targetChar:FindFirstChild("HumanoidRootPart") and myHRP then
        local targetHRP = targetChar.HumanoidRootPart
        
        -- แก้ไขเฉพาะสกิล 4: ระยะ 30 เมตร + ล็อคดักหน้า 360 องศา
        if skillEnabled then
            local frontPos = targetHRP.Position + (targetHRP.CFrame.LookVector * 30) 
            myHRP.CFrame = CFrame.new(frontPos, targetHRP.Position)
            
        elseif stickEnabled then
            local targetHum = targetChar:FindFirstChildOfClass("Humanoid")
            if targetHum then
                local moveDir = targetHum.MoveDirection
                local finalPos = (moveDir.Magnitude > 0) and (targetHRP.Position + (moveDir * 6) + Vector3.new(0, -5, 0)) or (targetHRP.CFrame * CFrame.new(0, -5, 4)).Position
                if moveDir.Magnitude > 0 then sendAttack("LeftClick") else sendAttack("LeftClickRelease") end
                myHRP.CFrame = CFrame.new(finalPos, targetHRP.Position)
            end
        end
    end
end)

