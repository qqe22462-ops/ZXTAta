local selectedTargetName = ""
local stickEnabled = false

-- [[ ฟังก์ชันอัปเดตรายชื่อ (หวานเจี๊ยบ Edition) ]]
local function updatePlayerList()
    -- ลบปุ่มเก่าออก
    for _, item in pairs(scroll:GetChildren()) do
        if item:IsA("TextButton") then item:Destroy() end
    end
    
    -- สร้างปุ่มใหม่
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then
            local pBtn = Instance.new("TextButton", scroll)
            pBtn.Size = UDim2.new(1, -10, 0, 35)
            pBtn.Text = p.DisplayName
            pBtn.BackgroundColor3 = (selectedTargetName == p.Name) and Color3.fromRGB(0, 180, 255) or Color3.fromRGB(40, 40, 40)
            pBtn.TextColor3 = Color3.new(1, 1, 1)
            pBtn.TextSize = 14; Instance.new("UICorner", pBtn)
            
            pBtn.MouseButton1Click:Connect(function()
                selectedTargetName = p.Name
                updatePlayerList() -- รีเฟรชสี
                if not stickEnabled then toggleBtn.Text = "เริ่มสิง: "..p.DisplayName end
            end)
        end
    end
end

-- อัปเดตชื่อทุก 1 วินาที (คนเข้า-ออก)
task.spawn(function()
    while task.wait(1) do
        updatePlayerList()
        if selectedTargetName ~= "" and not Players:FindFirstChild(selectedTargetName) then
            selectedTargetName = ""; stickEnabled = false
            toggleBtn.Text = "เป้าหมายหลุดแล้ว"; toggleBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        end
    end
end)

-- [[ ระบบวาร์ปดักหน้าตามทิศทาง 360 องศา - ระยะ 6 เมตร ]]
RunService.Heartbeat:Connect(function()
    if stickEnabled and selectedTargetName ~= "" then
        local target = Players:FindFirstChild(selectedTargetName)
        if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            local targetHRP = target.Character.HumanoidRootPart
            local targetHum = target.Character:FindFirstChildOfClass("Humanoid")
            
            if targetHum and humanoidRootPart then
                local moveDir = targetHum.MoveDirection
                local finalPos
                
                if moveDir.Magnitude > 0 then
                    -- ดักหน้าทิศที่เดิน 6 เมตร + มุดดิน 5 เมตร
                    finalPos = targetHRP.Position + (moveDir * 6) + Vector3.new(0, -5, 0)
                else
                    -- ถ้ายืนเฉยๆ ดักหน้าตัว 6 เมตร + มุดดิน 5 เมตร
                    finalPos = (targetHRP.CFrame * CFrame.new(0, -5, -6)).Position
                end
                
                -- วาร์ปไปจ้องเป้าหมาย
                humanoidRootPart.CFrame = CFrame.new(finalPos, targetHRP.Position)
            end
        end
    end
end)

toggleBtn.MouseButton1Click:Connect(function()
    if selectedTargetName == "" then return end
    stickEnabled = not stickEnabled
    toggleBtn.Text = stickEnabled and "สิงอยู่: ON" or "หยุดสิง: OFF"
    toggleBtn.BackgroundColor3 = stickEnabled and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 0, 0)
end)

-- [[ ระบบลาก UI (Drag) ]]
local dragging, dragInput, dragStart, startPos
mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = mainFrame.Position
    end
end)
UIS.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
end)
