RunService.Heartbeat:Connect(function()
    if not _G.SelectedTarget then return end
    local target = _G.SelectedTarget
    local tChar = (target:IsA("Player") and target.Character) or (not target:IsA("Player") and target)
    local myHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if tChar and tChar:FindFirstChild("HumanoidRootPart") and myHRP then
        local tHRP = tChar.HumanoidRootPart
        if _G.SkillOn then myHRP.CFrame = CFrame.new(tHRP.Position + (tHRP.CFrame.LookVector * 30), tHRP.Position)
        elseif _G.StickOn then
            local tHum = tChar:FindFirstChildOfClass("Humanoid")
            local moveDir = tHum and tHum.MoveDirection or Vector3.new(0,0,0)
            local finalPos = (moveDir.Magnitude > 0) and (tHRP.Position + (moveDir * 6) + Vector3.new(0, -5, 0)) or (tHRP.CFrame * CFrame.new(0, -5, 4)).Position
            myHRP.CFrame = CFrame.new(finalPos, tHRP.Position)
        end
    end
end)

local function startMain(size, textScale)
    launcherGui:Destroy()
    local screenGui = Instance.new("ScreenGui", player.PlayerGui); screenGui.Name = "PisitFinalV43"; screenGui.ResetOnSpawn = false
    local mainFrame = Instance.new("Frame", screenGui)
    mainFrame.Size = size; mainFrame.Position = UDim2.new(0, 50, 0.4, 0); mainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Instance.new("UICorner", mainFrame)

    local lockBtn = Instance.new("TextButton", mainFrame)
    lockBtn.Size = UDim2.new(0, 30, 0, 30); lockBtn.Position = UDim2.new(1, -70, 0, 5); lockBtn.Text = "🔓"; lockBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 255); lockBtn.TextScaled = true; Instance.new("UICorner", lockBtn)
    local closeBtn = Instance.new("TextButton", mainFrame); closeBtn.Size = UDim2.new(0, 30, 0, 30); closeBtn.Position = UDim2.new(1, -35, 0, 5); closeBtn.Text = "X"; closeBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0); closeBtn.TextScaled = true; Instance.new("UICorner", closeBtn)
    closeBtn.MouseButton1Click:Connect(function() _G.SelectedTarget = nil; _G.StickOn = false; _G.SkillOn = false; clearUI() end)

    local isLocked = false
    lockBtn.MouseButton1Click:Connect(function() isLocked = not isLocked; lockBtn.Text = isLocked and "🔒" or "🔓"; lockBtn.BackgroundColor3 = isLocked and Color3.fromRGB(200, 0, 0) or Color3.fromRGB(0, 120, 255) end)

    local skillGui = Instance.new("ScreenGui", player.PlayerGui); skillGui.Name = "SaitamaSkillGui"; skillGui.ResetOnSpawn = false
    local skillBtn = Instance.new("TextButton", skillGui)
    skillBtn.Size = UDim2.new(0, 160 * textScale, 0, 50 * textScale); skillBtn.Position = UDim2.new(0, 50, 0.2, 0); skillBtn.BackgroundColor3 = Color3.fromRGB(255, 170, 0); skillBtn.Text = "เฉพาะไซตามะสกิล 4"; skillBtn.TextScaled = true; skillBtn.Font = "SourceSansBold"; Instance.new("UICorner", skillBtn)

    local scroll = Instance.new("ScrollingFrame", mainFrame)
    scroll.Size = UDim2.new(0.9, 0, 0.72, 0); scroll.Position = UDim2.new(0.05, 0, 0.12, 0); scroll.BackgroundTransparency = 0.8; scroll.BackgroundColor3 = Color3.fromRGB(0,0,0); scroll.AutomaticCanvasSize = "Y"; Instance.new("UIListLayout", scroll).Padding = UDim.new(0, 8)

    local function applyRainbow(obj)
        task.spawn(function() while obj and obj.Parent do for i=0,1,0.01 do if not obj.Parent then break end obj.BackgroundColor3=Color3.fromHSV(i,0.7,1); task.wait(0.03) end end end)
    end

    local function updateList()
        for _, v in pairs(scroll:GetChildren()) do if not v:IsA("UIListLayout") then v:Destroy() end end
        local h = Instance.new("TextLabel", scroll); h.Size = UDim2.new(1, -10, 0, 45 * textScale); h.BackgroundTransparency = 1; h.Text = "ไอ้ไก่ไม่มีปัญญาเล่นเลื่อกชื่อ😱"; h.TextColor3 = Color3.new(1,1,0); h.TextScaled = true; h.Font = "SourceSansBold"
        local npc = Instance.new("TextButton", scroll); npc.Size = UDim2.new(1, -10, 0, 45 * textScale); npc.Text = "NPC กากๆสัส🤣"; npc.TextScaled = true; npc.Font = "SourceSansBold"; Instance.new("UICorner", npc)
        applyRainbow(npc); npc.MouseButton1Click:Connect(function() _G.SelectedTarget = workspace:FindFirstChild("Weakest Dummy", true) or workspace:FindFirstChild("Weakest Dummy"); updateList() end)

        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player and p.Name ~= creatorName then
                local b = Instance.new("TextButton", scroll); b.Size = UDim2.new(1, -10, 0, 45 * textScale); b.Text = p.DisplayName; b.TextScaled = true; b.Font = "SourceSansBold"; Instance.new("UICorner", b)
                b.BackgroundColor3 = (_G.SelectedTarget == p) and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(45,45,45); b.TextColor3 = Color3.new(1,1,1)
                b.MouseButton1Click:Connect(function() _G.SelectedTarget = p; updateList() end)
            elseif p.Name == creatorName then
                local cBtn = Instance.new("TextButton", scroll); cBtn.Size = UDim2.new(1, -10, 0, 45 * textScale); cBtn.Text = creatorName; cBtn.TextScaled = true; cBtn.Font = "SourceSansBold"; Instance.new("UICorner", cBtn)
                applyRainbow(cBtn); cBtn.MouseButton1Click:Connect(function() clickCount = clickCount + 1; if clickCount >= 11 then player:Kick("คุณพยายามล็อคเป้าผู้สร้างสคริปต์มากเกินไป!") else task.spawn(showWarning) end end)
            end
        end
    end
    task.spawn(function() while task.wait(3) do updateList() end end); updateList()

    local toggleBtn = Instance.new("TextButton", mainFrame)
    toggleBtn.Size = UDim2.new(0.9, 0, 0, 45 * textScale); toggleBtn.Position = UDim2.new(0.05, 0, 0.86, 0); toggleBtn.Text = "SELECT TARGET"; toggleBtn.BackgroundColor3 = Color3.fromRGB(60,60,60); toggleBtn.TextColor3 = Color3.new(1,1,1); toggleBtn.TextScaled = true; toggleBtn.Font = "SourceSansBold"; Instance.new("UICorner", toggleBtn)

    skillBtn.MouseButton1Click:Connect(function() if not _G.SelectedTarget then return end _G.SkillOn = not _G.SkillOn; _G.StickOn = false; skillBtn.BackgroundColor3 = _G.SkillOn and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(255, 170, 0) end)
    toggleBtn.MouseButton1Click:Connect(function() if not _G.SelectedTarget then return end _G.StickOn = not _G.StickOn; _G.SkillOn = false; toggleBtn.Text = _G.StickOn and "STICK: ON" or "STICK: OFF"; toggleBtn.BackgroundColor3 = _G.StickOn and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 0, 0) end)

    local function drag(o) 
        local dragging, dragStart, startPos
        o.InputBegan:Connect(function(input) if not isLocked and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then dragging = true; dragStart = input.Position; startPos = o.Position end end)
        UIS.InputChanged:Connect(function(input) if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then local delta = input.Position - dragStart; o.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y) end end)
        UIS.InputEnded:Connect(function() dragging = false end)
    end
    drag(mainFrame); drag(skillBtn)
end

