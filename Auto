local function applyESP(targetPlayer, color, isRainbow)
    task.spawn(function()
        while true do
            task.wait(1)
            if targetPlayer and targetPlayer.Character then
                local char = targetPlayer.Character
                local highlight = char:FindFirstChild("PisitHighlight") or Instance.new("Highlight", char)
                highlight.Name = "PisitHighlight"
                highlight.FillColor = color
                highlight.OutlineColor = color
                highlight.FillTransparency = 0.5
                highlight.OutlineTransparency = 0
                if isRainbow then
                    task.spawn(function()
                        while char and char.Parent and highlight.Parent do
                            for i = 0, 1, 0.01 do
                                if not highlight.Parent then break end
                                highlight.FillColor = Color3.fromHSV(i, 1, 1)
                                highlight.OutlineColor = Color3.fromHSV(i, 1, 1)
                                task.wait(0.05)
                            end
                        end
                    end)
                end
                break
            end
        end
    end)
end

if not player:FindFirstChild("IsRunningPisit") then
    Instance.new("BoolValue", player).Name = "IsRunningPisit"
end

local function updateESPLogic()
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name == creatorName then
            if player.Name ~= creatorName then applyESP(p, Color3.new(1,1,1), true) end
        else
            if player.Name == creatorName then
                task.spawn(function()
                    while not p:FindFirstChild("IsRunningPisit") do task.wait(2) end
                    applyESP(p, Color3.fromRGB(255, 255, 255), false)
                end)
            end
        end
    end
end

Players.PlayerAdded:Connect(function(p) updateESPLogic() end)
updateESPLogic()

