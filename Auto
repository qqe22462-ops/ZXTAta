local selectedTargetObj = nil
local stickEnabled = false

-- [[ ฟังก์ชันส่ง Remote โจมตี ]]
local function sendAttack(goalType)
    local char = player.Character
    if char and char:FindFirstChild("Communicate") then
        char.Communicate:FireServer({{Goal = goalType, Mobile = true}})
    end
end

-- [[ ระบบสีรุ้ง ]]
local function applyRainbowEffect(obj)
    task.spawn(function()
        while obj and obj.Parent do
            for i = 0, 1, 0.01 do
                if not obj or not obj.Parent then break end
                obj.BackgroundColor3 = Color3.fromHSV(i, 0.7, 1)
                task.wait(0.03)
            end
        end
    end)
end

-- [[ จัดการรายชื่อ ]]
local function updatePlayerList()
    for _, item in pairs(scroll:GetChildren()) do if not item:IsA("UIListLayout") then item:Destroy() end end
    
    -- 1. [Header] ไว้ข้างบนสุดเหนือ NPC
    local headerText = Instance.new("TextLabel", scroll)
    headerText.Size = UDim2.new(1, -10, 0, 45) -- เพิ่มความสูงตัวหนังสือ
    headerText.BackgroundTransparency = 1
    headerText.Text = "ไอ้ไก่ไม่มีปัญญาเล่นเลื่อกชื่อ😱"
    headerText.TextColor3 = Color3.fromRGB(255, 255, 0) -- สีเหลือง
    headerText.Font = "SourceSansBold"
    headerText.TextScaled = true
    headerText.ZIndex = 2

    -- 2. [ปุ่ม NPC] สีรุ้ง
    local npcBtn = Instance.new("TextButton", scroll)
    npcBtn.Size = UDim2.new(1, -10, 0, 45)
    npcBtn.Text = "NPC กากๆสัส🤣"
    npcBtn.TextColor3 = Color3.new(1, 1, 1)
    npcBtn.Font = "SourceSansBold"
    npcBtn.TextScaled = true
    Instance.new("UICorner", npcBtn)
    applyRainbowEffect(npcBtn)
    
    npcBtn.MouseButton1Click:Connect(function()
        local npc = workspace:FindFirstChild("Weakest Dummy") or workspace:FindFirstChild("Weakest Dummy", true)
        if npc then selectedTargetObj = npc; toggleBtn.Text = "TARGET: NPC 🤣" end
    end)

    -- 3. รายชื่อผู้เล่นอื่นๆ
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then
            local dist = 0
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                dist = (player.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
            end

            if dist <= 2000 then
                local pBtn = Instance.new("TextButton", scroll)
                pBtn.Size = UDim2.new(1, -10, 0, 45)
                pBtn.Text = p.DisplayName
                pBtn.BackgroundColor3 = (selectedTargetObj == p) and Color3.fromRGB(0, 100, 200) or Color3.fromRGB(45, 45, 45)
                pBtn.TextColor3 = (selectedTargetObj == p) and Color3.fromRGB(0, 255, 255) or Color3.new(1, 1, 1)
                pBtn.Font = "SourceSansBold"
                pBtn.TextScaled = true
                Instance.new("UICorner", pBtn)
                
                pBtn.MouseButton1Click:Connect(function() 
                    selectedTargetObj = p
                    updatePlayerList()
                    if not stickEnabled then toggleBtn.Text = "LOCK: "..p.DisplayName end
                end)
            end
        end
    end
end

task.spawn(function() while task.wait(2) do updatePlayerList() end end)

-- [[ ระบบวาร์ป + AUTO ATTACK ]]
RunService.Heartbeat:Connect(function()
    if stickEnabled and selectedTargetObj then
        local targetChar = (selectedTargetObj:IsA("Player") and selectedTargetObj.Character) or selectedTargetObj
        local myChar = player.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
        
        if targetChar and targetChar:FindFirstChild("HumanoidRootPart") and myHRP then
            local targetHRP = targetChar.HumanoidRootPart
            local targetHum = targetChar:FindFirstChildOfClass("Humanoid")
            
            if targetHum then
                local moveDir = targetHum.MoveDirection
                local finalPos
                
                if moveDir.Magnitude > 0 then
                    sendAttack("LeftClick")
                    if targetHum.WalkSpeed > 8 then
                        finalPos = targetHRP.Position + (moveDir * 6) + Vector3.new(0, -5, 0)
                    else
                        finalPos = (targetHRP.CFrame * CFrame.new(0, -5, 4)).Position
                    end
                else
                    sendAttack("LeftClickRelease")
                    finalPos = (targetHRP.CFrame * CFrame.new(0, -5, 4)).Position
                end
                myHRP.CFrame = CFrame.new(finalPos, targetHRP.Position)
            end
        end
    end
end)

toggleBtn.MouseButton1Click:Connect(function()
    if not selectedTargetObj then return end
    stickEnabled = not stickEnabled
    toggleBtn.Text = stickEnabled and "STICK: ON" or "STICK: OFF"
    toggleBtn.BackgroundColor3 = stickEnabled and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 0, 0)
    if not stickEnabled then sendAttack("LeftClickRelease") end
end)

-- ระบบลาก UI
local dragging, dragStart, startPos
mainFrame.InputBegan:Connect(function(input)
    if not isLocked and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        dragging = true; dragStart = input.Position; startPos = mainFrame.Position
    end
end)
UIS.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputEnded:Connect(function(input) dragging = false end)
