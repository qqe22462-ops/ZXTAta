-- เน้นปุ่มใหญ่ อ่านง่าย ไม่บั๊ก

local LocalPlayer = game:GetService("Players").LocalPlayer
local UserInputService = game:GetService("UserInputService")
local MapID = tostring(game.PlaceId)
local IsSpamming = false

-- [[ 1. สร้าง UI ]]
local sg = Instance.new("ScreenGui", LocalPlayer.PlayerGui)
sg.Name = "PisitSimpleG"
sg.ResetOnSpawn = false

-- ปุ่ม G วงกลม (ลากได้)
local gBtn = Instance.new("TextButton", sg)
gBtn.Size = UDim2.new(0, 90, 0, 90)
gBtn.Position = UDim2.new(0, 50, 0.5, -45)
gBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
gBtn.Text = "G"
gBtn.TextSize = 50
gBtn.TextColor3 = Color3.new(1, 1, 1)
gBtn.Font = Enum.Font.SourceSansBold
Instance.new("UICorner", gBtn).CornerRadius = UDim.new(1, 0)

-- กรอบเมนูสีดำ (ตามภาพที่คุณส่งมา)
local mainFrame = Instance.new("Frame", sg)
mainFrame.Size = UDim2.new(0, 280, 0, 420)
mainFrame.Position = UDim2.new(0, 150, 0.5, -210)
mainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
mainFrame.Visible = false
Instance.new("UICorner", mainFrame)

-- ช่องใส่โค้ด
local codeBox = Instance.new("TextBox", mainFrame)
codeBox.Size = UDim2.new(1, -20, 0, 80)
codeBox.Position = UDim2.new(0, 10, 0, 10)
codeBox.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
codeBox.PlaceholderText = "วางโค้ดที่นี่..."
codeBox.Text = ""
codeBox.TextColor3 = Color3.new(1, 1, 1)
codeBox.TextSize = 18
codeBox.ClearTextOnFocus = false
Instance.new("UICorner", codeBox)

-- [[ หน้าต่างประวัติ (History) ]]
local historyFrame = Instance.new("Frame", sg)
historyFrame.Size = UDim2.new(0, 300, 0, 350)
historyFrame.Position = UDim2.new(0.5, -150, 0.5, -175)
historyFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
historyFrame.Visible = false
Instance.new("UICorner", historyFrame)

local closeHistory = Instance.new("TextButton", historyFrame)
closeHistory.Size = UDim2.new(0, 40, 0, 40)
closeHistory.Position = UDim2.new(1, -45, 0, 5)
closeHistory.Text = "X"
closeHistory.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
closeHistory.TextColor3 = Color3.new(1, 1, 1)

local scroll = Instance.new("ScrollingFrame", historyFrame)
scroll.Size = UDim2.new(1, -10, 1, -60)
scroll.Position = UDim2.new(0, 5, 0, 50)
scroll.BackgroundTransparency = 1
scroll.CanvasSize = UDim2.new(0, 0, 5, 0)
Instance.new("UIListLayout", scroll).Padding = UDim.new(0, 5)

-- [[ ฟังก์ชันสร้างปุ่มแบบง่าย ]]
local function MakeBtn(txt, color, yPos, callback)
    local btn = Instance.new("TextButton", mainFrame)
    btn.Size = UDim2.new(1, -20, 0, 55)
    btn.Position = UDim2.new(0, 10, 0, yPos)
    btn.BackgroundColor3 = color
    btn.Text = txt
    btn.TextSize = 22
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.SourceSansBold
    Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(callback)
    return btn
end

-- สร้าง 5 ปุ่ม
MakeBtn("1. คัดลอกโค้ด", Color3.fromRGB(0, 100, 255), 100, function()
    if setclipboard then setclipboard(codeBox.Text) end
end)

MakeBtn("2. รันโค้ด 1 ครั้ง", Color3.fromRGB(0, 150, 0), 165, function()
    if codeBox.Text ~= "" then loadstring(codeBox.Text)() end
end)

MakeBtn("3. บันทึกโค้ด", Color3.fromRGB(80, 80, 80), 230, function()
    if codeBox.Text == "" or not writefile then return end
    local folder = "PisitSaves/" .. MapID
    if not isfolder("PisitSaves") then makefolder("PisitSaves") end
    if not isfolder(folder) then makefolder(folder) end
    writefile(folder .. "/Save_" .. os.time() .. ".lua", codeBox.Text)
end)

MakeBtn("4. ประวัติบันทึก", Color3.fromRGB(100, 50, 150), 295, function()
    for _, v in pairs(scroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    local folder = "PisitSaves/" .. MapID
    if isfolder and isfolder(folder) then
        for _, file in pairs(listfiles(folder)) do
            local fBtn = Instance.new("TextButton", scroll)
            fBtn.Size = UDim2.new(1, -10, 0, 45)
            fBtn.Text = file:sub(#folder + 2)
            fBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            fBtn.TextColor3 = Color3.new(1, 1, 1)
            Instance.new("UICorner", fBtn)
            fBtn.MouseButton1Click:Connect(function()
                codeBox.Text = readfile(file)
                historyFrame.Visible = false
            end)
        end
    end
    historyFrame.Visible = true
end)

local sBtn = MakeBtn("5. รันรัวๆ: OFF", Color3.fromRGB(150, 0, 0), 360, function() end)
sBtn.MouseButton1Click:Connect(function()
    IsSpamming = not IsSpamming
    sBtn.Text = "5. รันรัวๆ: " .. (IsSpamming and "ON" or "OFF")
    sBtn.BackgroundColor3 = IsSpamming and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
    task.spawn(function()
        while IsSpamming do
            if codeBox.Text ~= "" then pcall(function() loadstring(codeBox.Text)() end) end
            task.wait(0.2)
        end
    end)
end)

-- [[ ระบบควบคุม ]]
gBtn.MouseButton1Click:Connect(function() mainFrame.Visible = not mainFrame.Visible end)
closeHistory.MouseButton1Click:Connect(function() historyFrame.Visible = false end)

-- ลากปุ่ม G
local d, ds, sp
gBtn.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then d = true ds = i.Position sp = gBtn.Position end end)
UserInputService.InputChanged:Connect(function(i) if d then 
    local del = i.Position - ds
    gBtn.Position = UDim2.new(sp.X.Scale, sp.X.Offset + del.X, sp.Y.Scale, sp.Y.Offset + del.Y)
    mainFrame.Position = UDim2.new(sp.X.Scale, sp.X.Offset + del.X + 100, sp.Y.Scale, sp.Y.Offset + del.Y - 210)
end end)
gBtn.InputEnded:Connect(function() d = false end)
