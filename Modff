-- ตัวแปรเก็บโค้ดชั่วคราว (จำลองโค้ดที่ได้จาก rspy)
local CurrentCode = "" 
local IsSpamming = false

-- [[ 1. สร้าง UI ขนาดประมาณ 3 นิ้ว (300x350 px) ]]
