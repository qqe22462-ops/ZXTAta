-- 4. ประวัติ (ม่วง)
CreateBtn("4. ประวัติการบันทึก", UDim2.new(0.5, -145, 0.71, 0), Color3.fromRGB(130, 60, 200), function()
    for _, v in pairs(scroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    local folder = "PisitSaves/" .. MapName
    if isfolder and isfolder(folder) then
        for _, file in pairs(listfiles(folder)) do
            local fBtn = Instance.new("TextButton", scroll)
            fBtn.Size = UDim2.new(1, -10, 0, 45)
            fBtn.Text = file:sub(#folder + 2)
            fBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
            fBtn.TextColor3 = Color3.new(1, 1, 1)
            fBtn.TextSize = 18
            Instance.new("UICorner", fBtn)
            fBtn.MouseButton1Click:Connect(function()
                codeBox.Text = readfile(file)
                historyFrame.Visible = false
            end)
        end
    end
    historyFrame.Visible = true
end)

-- 5. รันรัวๆ (แดง)
local sBtn = CreateBtn("5. รันรัวๆ: OFF", UDim2.new(0.5, -145, 0.86, 0), Color3.fromRGB(180, 0, 0), function() end)
sBtn.MouseButton1Click:Connect(function()
    IsSpamming = not IsSpamming
    sBtn.Text = "5. รันรัวๆ: " .. (IsSpamming and "ON" or "OFF")
    sBtn.BackgroundColor3 = IsSpamming and Color3.fromRGB(0, 180, 0) or Color3.fromRGB(180, 0, 0)
    if IsSpamming then
        task.spawn(function()
            while IsSpamming do
                if codeBox.Text ~= "" then pcall(function() loadstring(codeBox.Text)() end) end
                task.wait(0.2)
            end
        end)
    end
end)

-- [[ ระบบลากปุ่ม G ]]
gBtn.MouseButton1Click:Connect(function() mainFrame.Visible = not mainFrame.Visible end)
closeHistory.MouseButton1Click:Connect(function() historyFrame.Visible = false end)

local d, ds, sp
gBtn.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then d = true ds = i.Position sp = gBtn.Position end end)
UserInputService.InputChanged:Connect(function(i) if d then 
    local del = i.Position - ds
    gBtn.Position = UDim2.new(sp.X.Scale, sp.X.Offset + del.X, sp.Y.Scale, sp.Y.Offset + del.Y)
    mainFrame.Position = UDim2.new(sp.X.Scale, sp.X.Offset + del.X + 100, sp.Y.Scale, sp.Y.Offset + del.Y - 225)
end end)
UserInputService.InputEnded:Connect(function() d = false end)

