-- 3. บันทึก (เทา)
CreateBtn("3. บันทึกโค้ด", UDim2.new(0.5, -145, 0.59, 0), Color3.fromRGB(100, 100, 100), function()
    if codeBox.Text == "" or not writefile then return end
