local function openWinSystem(target)
    local wf = Instance.new("Frame", sg); wf.Size = UDim2.new(0, 200, 0, 120); wf.Position = UDim2.new(0.5, -100, 0.1, 0); wf.BackgroundColor3 = Color3.fromRGB(15,15,15); Instance.new("UICorner", wf)
    
    local winLock = {IsLocked = true}
    makePisitDraggable(wf, winLock)
    
    local lockBtn = Instance.new("TextButton", wf)
    lockBtn.Size = UDim2.new(0, 30, 0, 30); lockBtn.Position = UDim2.new(1, -35, 1, -35); lockBtn.Text = "🔒"; lockBtn.BackgroundTransparency = 1; lockBtn.TextSize = 20
    lockBtn.MouseButton1Click:Connect(function()
        winLock.IsLocked = not winLock.IsLocked
        lockBtn.Text = winLock.IsLocked and "🔒" or "🔓"
    end)

    local val = 0
    local d = Instance.new("TextLabel", wf); d.Size = UDim2.new(1,0,0.7,0); d.BackgroundTransparency = 1; d.Text = val.."/"..target.." Win"; d.TextColor3 = Color3.new(1,1,0); d.Font = "SourceSansBold"; d.TextSize = 40
    local p = Instance.new("TextButton", wf); p.Size = UDim2.new(0,35,0,35); p.Position = UDim2.new(0,5,0,5); p.Text = "+"; p.BackgroundColor3 = Color3.fromRGB(0,180,0); Instance.new("UICorner", p); p.MouseButton1Click:Connect(function() val = val + 1; d.Text = val.."/"..target.." Win" end)
    local m = Instance.new("TextButton", wf); m.Size = UDim2.new(0,35,0,35); m.Position = UDim2.new(1,-40,0,5); m.Text = "-"; m.BackgroundColor3 = Color3.fromRGB(180,0,0); Instance.new("UICorner", m); m.MouseButton1Click:Connect(function() val = val - 1; d.Text = val.."/"..target.." Win" end)
    
    mainFrame.Visible = true
end

