-- [[ BATTLE LOGIC ]]
----------------------------------------------------------------
local function shootArrow()
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local target = player.Character:FindFirstChild("UpperTorso") or hrp
    local angle = math.rad(math.random(0, 360))
    local spawnPos = target.Position + Vector3.new(math.cos(angle)*25, 5, math.sin(angle)*25)
    local arrow = Instance.new("Part", workspace)
    arrow.Size = Vector3.new(0.4, 0.4, 4); arrow.Anchored = true; arrow.CFrame = CFrame.lookAt(spawnPos, target.Position)
    TweenService:Create(arrow, TweenInfo.new(0.12), {CFrame = CFrame.lookAt(target.Position, target.Position + arrow.CFrame.LookVector) * CFrame.new(0, 0, 2)}):Play()
    task.wait(0.12); arrow.Anchored = false
    Instance.new("WeldConstraint", arrow).Part0 = arrow; arrow.WeldConstraint.Part1 = target
    local v = Instance.new("BodyVelocity", hrp); v.MaxForce = Vector3.new(4e5, 0, 4e5); v.Velocity = arrow.CFrame.LookVector * 30; Debris:AddItem(v, 0.1)
    task.delay(1, function() if arrow then TweenService:Create(arrow, TweenInfo.new(0.5), {Transparency = 1}):Play(); Debris:AddItem(arrow, 0.5) end end)
end

-- ฟังก์ชันสร้างบล็อกที่หายไป
local function createBlock()
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then 
        local block = Instance.new("Part", workspace)
        block.Size = Vector3.new(12, 12, 1.2); block.CFrame = (hrp.CFrame * CFrame.new(0, 0, -4)) + Vector3.new(0, 2.5, 0) 
        block.Anchored = true; block.CanCollide = true; block.BrickColor = BrickColor.new("Cyan"); block.Material = "Neon"
        task.delay(1.5, function() TweenService:Create(block, TweenInfo.new(0.5), {Transparency = 1}):Play() end)
        Debris:AddItem(block, 2) 
    end
end

